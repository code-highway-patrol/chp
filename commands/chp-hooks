#!/bin/bash
# chp-hooks - Manage CHP hook types
#
# This command provides a CLI for managing hook types:
# - List all hooks with their status
# - Enable/disable hooks
# - Set blocking behavior
# - Install/uninstall hook templates
# - Detect available hook types
# - Show hook registry

set -e

# Source core modules
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"
source "$SCRIPT_DIR/../core/hook-registry.sh"
source "$SCRIPT_DIR/../core/detector.sh"
source "$SCRIPT_DIR/../core/installer.sh"

# Show usage information
show_usage() {
    cat << 'EOF'
Usage: chp-hooks <subcommand> [options]

Subcommands:
  list                          List all hooks with their status
  ensure                        Ensure all registered hooks are installed
  enable <hook-type>            Enable a hook type
  disable <hook-type>           Disable a hook type
  blocking <hook-type> [true]   Set blocking behavior (default: true)
  install <hook-type>           Install hook template
  uninstall <hook-type>         Uninstall hook template
  detect                        Detect available hook types in current environment
  registry                      Show hook registry JSON

Examples:
  chp-hooks list                           # List all hooks and their status
  chp-hooks ensure                         # Ensure all registered hooks are installed
  chp-hooks enable pre-commit              # Enable pre-commit hook
  chp-hooks disable pre-push               # Disable pre-push hook
  chp-hooks blocking commit-msg false      # Set commit-msg to non-blocking
  chp-hooks install pre-commit             # Install pre-commit hook template
  chp-hooks uninstall pre-commit           # Uninstall pre-commit hook template
  chp-hooks detect                         # Detect available hook types
  chp-hooks registry                       # Show hook registry JSON

For more information, see: https://github.com/your-repo/chp
EOF
}

# List all hooks with their status
cmd_list() {
    # Initialize registry if needed
    init_hook_registry

    # Print header
    printf "%-20s %-10s %-10s %-10s\n" "Hook Type" "Enabled" "Blocking" "Laws"
    printf "%-20s %-10s %-10s %-10s\n" "----------" "-------" "--------" "----"

    # Get all available hooks
    local hooks
    hooks=$(detect_all_hooks)

    if [ -z "$hooks" ]; then
        log_warn "No hooks detected in current environment"
        return 0
    fi

    # Iterate through each hook type
    for hook_type in $hooks; do
        # Get enabled status
        local enabled="no"
        if is_hook_enabled "$hook_type" 2>/dev/null; then
            enabled="yes"
        fi

        # Get blocking status
        local blocking="no"
        if is_hook_blocking "$hook_type" 2>/dev/null; then
            blocking="yes"
        fi

        # Get law count
        local laws
        laws=$(get_hook_laws "$hook_type" 2>/dev/null)
        local law_count=0
        if [ -n "$laws" ] && [ "$laws" != "[]" ] && [ "$laws" != "" ]; then
            # Count non-empty items in the array
            law_count=$(echo "$laws" | jq 'length' 2>/dev/null || echo "0")
        fi

        # Print row
        printf "%-20s %-10s %-10s %-10s\n" "$hook_type" "$enabled" "$blocking" "$law_count"
    done
}

# Ensure all registered hooks are installed
cmd_ensure() {
    init_hook_registry
    ensure_hooks_installed
}

# Enable a hook type
cmd_enable() {
    local hook_type="$1"

    if [ -z "$hook_type" ]; then
        log_error "Hook type is required"
        echo "Usage: chp-hooks enable <hook-type>"
        exit 1
    fi

    # Check if hook type is valid
    local category
    category=$(get_hook_category "$hook_type")
    if [ "$category" = "unknown" ]; then
        log_error "Unknown hook type: $hook_type"
        echo "Run 'chp-hooks detect' to see available hook types"
        exit 1
    fi

    # Enable the hook
    set_hook_enabled "$hook_type" "true"
    log_info "Hook '$hook_type' enabled"
}

# Disable a hook type
cmd_disable() {
    local hook_type="$1"

    if [ -z "$hook_type" ]; then
        log_error "Hook type is required"
        echo "Usage: chp-hooks disable <hook-type>"
        exit 1
    fi

    # Check if hook type is valid
    local category
    category=$(get_hook_category "$hook_type")
    if [ "$category" = "unknown" ]; then
        log_error "Unknown hook type: $hook_type"
        echo "Run 'chp-hooks detect' to see available hook types"
        exit 1
    fi

    # Disable the hook
    set_hook_enabled "$hook_type" "false"
    log_info "Hook '$hook_type' disabled"
}

# Set blocking behavior for a hook type
cmd_blocking() {
    local hook_type="$1"
    local blocking="${2:-true}"

    if [ -z "$hook_type" ]; then
        log_error "Hook type is required"
        echo "Usage: chp-hooks blocking <hook-type> [true|false]"
        exit 1
    fi

    # Check if hook type is valid
    local category
    category=$(get_hook_category "$hook_type")
    if [ "$category" = "unknown" ]; then
        log_error "Unknown hook type: $hook_type"
        echo "Run 'chp-hooks detect' to see available hook types"
        exit 1
    fi

    # Normalize blocking value
    if [ "$blocking" != "true" ] && [ "$blocking" != "false" ]; then
        log_error "Blocking value must be 'true' or 'false'"
        exit 1
    fi

    # Set blocking behavior
    set_hook_blocking "$hook_type" "$blocking"
    log_info "Hook '$hook_type' blocking set to $blocking"
}

# Install a hook template
cmd_install() {
    local hook_type="$1"

    if [ -z "$hook_type" ]; then
        log_error "Hook type is required"
        echo "Usage: chp-hooks install <hook-type>"
        exit 1
    fi

    # Check if hook type is valid
    local category
    category=$(get_hook_category "$hook_type")
    if [ "$category" = "unknown" ]; then
        log_error "Unknown hook type: $hook_type"
        echo "Run 'chp-hooks detect' to see available hook types"
        exit 1
    fi

    # Install the hook template
    install_hook_template "$hook_type" "$category"
}

# Uninstall a hook template
cmd_uninstall() {
    local hook_type="$1"

    if [ -z "$hook_type" ]; then
        log_error "Hook type is required"
        echo "Usage: chp-hooks uninstall <hook-type>"
        exit 1
    fi

    # Check if hook type is valid
    local category
    category=$(get_hook_category "$hook_type")
    if [ "$category" = "unknown" ]; then
        log_error "Unknown hook type: $hook_type"
        echo "Run 'chp-hooks detect' to see available hook types"
        exit 1
    fi

    # Uninstall the hook template
    uninstall_hook_template "$hook_type" "$category"
}

# Detect available hook types
cmd_detect() {
    log_info "Detecting available hook types..."

    # Detect all hooks
    local hooks
    hooks=$(detect_all_hooks)

    if [ -z "$hooks" ]; then
        log_warn "No hooks detected in current environment"
        return 0
    fi

    # Group by category
    echo ""
    echo "Git Hooks:"
    local git_hooks="pre-commit post-commit pre-push post-merge commit-msg prepare-commit-msg pre-rebase post-checkout post-rewrite applypatch-msg pre-applypatch post-applypatch update pre-auto-gc post-update"
    for hook in $hooks; do
        if echo "$git_hooks" | grep -qw "$hook"; then
            echo "  - $hook"
        fi
    done

    echo ""
    echo "Agent Hooks:"
    local agent_hooks="pre-prompt post-prompt pre-tool post-tool pre-response post-response"
    local found_agent=false
    for hook in $hooks; do
        if echo "$agent_hooks" | grep -qw "$hook"; then
            echo "  - $hook"
            found_agent=true
        fi
    done
    if [ "$found_agent" = "false" ]; then
        echo "  (none - requires .claude directory)"
    fi

    echo ""
    log_info "Total available hooks: $(echo "$hooks" | wc -w | tr -d ' ')"
}

# Show hook registry JSON
cmd_registry() {
    # Initialize registry if needed
    init_hook_registry

    # Pretty print the registry
    jq '.' "$HOOK_REGISTRY"
}

# Main execution
main() {
    # Check if subcommand provided
    if [ $# -eq 0 ]; then
        show_usage
        exit 0
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        list)
            cmd_list
            ;;
        ensure)
            cmd_ensure
            ;;
        enable)
            cmd_enable "$@"
            ;;
        disable)
            cmd_disable "$@"
            ;;
        blocking)
            cmd_blocking "$@"
            ;;
        install)
            cmd_install "$@"
            ;;
        uninstall)
            cmd_uninstall "$@"
            ;;
        detect)
            cmd_detect
            ;;
        registry)
            cmd_registry
            ;;
        help|--help|-h)
            show_usage
            ;;
        *)
            log_error "Unknown subcommand: $subcommand"
            echo ""
            show_usage
            exit 1
            ;;
    esac
}

# Run main
main "$@"
