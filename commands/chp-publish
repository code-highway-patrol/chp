#!/usr/bin/env bash
# CHP Publish - Upload laws to the marketplace

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"

MARKETPLACE_API="${CHP_MARKETPLACE_API:-https://www.pinkdonut.work/api}"
LAWS_DIR="docs/chp/laws"

show_usage() {
    cat <<EOF
CHP Publish - Upload laws to the marketplace

Usage: chp-publish <law-name> [options]

Arguments:
    law-name              Name of the law directory (e.g., no-console-log)

Options:
    -t, --title <title>       Custom title (default: derived from law name)
    -d, --description <desc>  Law description
    --tags <tags>             Comma-separated tags (e.g., "javascript,security")
    --author <name>           Author name (default: from Supabase profile)
    --token-file <path>       Read Supabase auth token from file (recommended)
    --token-stdin            Read token from stdin (secure)
    --dry-run                 Validate and show payload without uploading
    -v, --verbose             Show detailed output

Environment:
    CHP_PUBLISH_TOKEN         Supabase auth token for marketplace uploads
    CHP_PUBLISH_TOKEN_FILE    Path to file containing token

Examples:
    chp-publish no-console-log
    chp-publish no-console-log --title "No Console Logging" --tags "javascript,logging"
    chp-publish my-law --token-file ~/.config/chp/token
    echo "eyJ..." | chp-publish my-law --token-stdin

To get a Supabase token:
    1. Go to https://pinkdonut.work (the marketplace site)
    2. Sign in with Supabase
    3. Open browser DevTools → Application → Local Storage
    4. Copy the access token
EOF
}

# Parse arguments
law_name=""
custom_title=""
custom_description=""
custom_tags=""
custom_author=""
token_file=""
token_from_stdin=""
deprecated_token=""
dry_run=""
verbose=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_usage
            exit 0
            ;;
        -t|--title)
            custom_title="$2"
            shift 2
            ;;
        -d|--description)
            custom_description="$2"
            shift 2
            ;;
        --tags)
            custom_tags="$2"
            shift 2
            ;;
        --author)
            custom_author="$2"
            shift 2
            ;;
        --token-file)
            token_file="$2"
            shift 2
            ;;
        --token-stdin)
            token_from_stdin="true"
            shift
            ;;
        --token)
            echo "Warning: --token is deprecated (visible in process list). Use --token-file or CHP_PUBLISH_TOKEN instead." >&2
            deprecated_token="$2"
            shift 2
            ;;
        --dry-run)
            dry_run="true"
            shift
            ;;
        -v|--verbose)
            verbose="true"
            shift
            ;;
        -*)
            echo "Error: unknown option: $1" >&2
            echo ""
            show_usage
            exit 1
            ;;
        *)
            if [[ -z "$law_name" ]]; then
                law_name="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$law_name" ]]; then
    echo "Error: law name is required" >&2
    echo ""
    show_usage
    exit 1
fi

# Validate law name to prevent path traversal
if [[ "$law_name" =~ \.\. ]] || [[ "$law_name" =~ ^/ ]] || [[ "$law_name" =~ [/\\] ]]; then
    echo "Error: invalid law name (contains path traversal or separators): $law_name" >&2
    exit 1
fi

# Check if law directory exists
law_path="$LAWS_DIR/$law_name"
if [[ ! -d "$law_path" ]]; then
    echo "Error: law directory not found: $law_path" >&2
    echo "Hint: Laws should be in $LAWS_DIR/<name>/" >&2
    exit 1
fi

# Check for required files (all three are required for marketplace)
law_json="$law_path/law.json"
guidance="$law_path/guidance.md"
verify="$law_path/verify.sh"
missing_files=()

if [[ ! -f "$law_json" ]]; then
    missing_files+=("law.json")
fi

if [[ ! -f "$guidance" ]]; then
    missing_files+=("guidance.md")
fi

if [[ ! -f "$verify" ]]; then
    missing_files+=("verify.sh")
fi

if [[ ${#missing_files[@]} -gt 0 ]]; then
    echo "Error: law is missing required files: ${missing_files[*]}" >&2
    echo "" >&2
    echo "Marketplace laws require all three files:" >&2
    echo "  - law.json (law configuration)" >&2
    echo "  - guidance.md (documentation)" >&2
    echo "  - verify.sh (verification script)" >&2
    echo "" >&2
    echo "Path: $law_path" >&2
    exit 1
fi

# Get auth token (skip for dry-run)
if [[ -z "$dry_run" ]]; then
    # Priority order for token sources (most secure first):
    # 1. --token-file <path>
    # 2. CHP_PUBLISH_TOKEN_FILE env var
    # 3. --token-stdin
    # 4. CHP_PUBLISH_TOKEN env var
    # 5. --token (deprecated, warns user)
    # 6. Stored auth file

    token=""

    if [[ -n "$token_file" ]]; then
        if [[ ! -f "$token_file" ]]; then
            echo "Error: token file not found: $token_file" >&2
            exit 1
        fi
        token=$(cat "$token_file" 2>/dev/null | tr -d '\n\r' | tr -d ' ')
        if [[ -z "$token" ]]; then
            echo "Error: token file is empty: $token_file" >&2
            exit 1
        fi
    elif [[ -n "$CHP_PUBLISH_TOKEN_FILE" ]]; then
        if [[ ! -f "$CHP_PUBLISH_TOKEN_FILE" ]]; then
            echo "Error: token file not found: $CHP_PUBLISH_TOKEN_FILE" >&2
            exit 1
        fi
        token=$(cat "$CHP_PUBLISH_TOKEN_FILE" 2>/dev/null | tr -d '\n\r' | tr -d ' ')
        if [[ -z "$token" ]]; then
            echo "Error: token file is empty: $CHP_PUBLISH_TOKEN_FILE" >&2
            exit 1
        fi
    elif [[ -n "$token_from_stdin" ]]; then
        token=$(cat 2>/dev/null | tr -d '\n\r' | tr -d ' ')
        if [[ -z "$token" ]]; then
            echo "Error: no token provided via stdin" >&2
            exit 1
        fi
    elif [[ -n "$CHP_PUBLISH_TOKEN" ]]; then
        token="$CHP_PUBLISH_TOKEN"
    elif [[ -n "$deprecated_token" ]]; then
        token="$deprecated_token"
    fi

    # Fall back to stored auth if no token provided
    if [[ -z "$token" ]]; then
        AUTH_FILE="$HOME/.chp/auth.json"
        if [[ -f "$AUTH_FILE" ]]; then
            token=$(jq -r '.token // empty' "$AUTH_FILE" 2>/dev/null)
        fi
    fi

    if [[ -z "$token" ]]; then
        echo "Error: No auth token found" >&2
        echo "" >&2
        echo "Provide a token via:" >&2
        echo "  1. --token-file <path>     (recommended)" >&2
        echo "  2. CHP_PUBLISH_TOKEN_FILE=<path>" >&2
        echo "  3. echo <token> | chp-publish ... --token-stdin" >&2
        echo "  4. CHP_PUBLISH_TOKEN=<token>" >&2
        echo "" >&2
        echo "Or sign in with: chp login" >&2
        exit 1
    fi
else
    # For dry-run, try to get token for validation but don't fail if missing
    token="${deprecated_token:-$CHP_PUBLISH_TOKEN}"
    if [[ -z "$token" ]]; then
        token="(dry-run - no token)"
    fi
fi

# Read law.json for metadata
if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq is required" >&2
    exit 1
fi

law_title=$(jq -r '.name // .title // empty' "$law_json" 2>/dev/null)
law_intent=$(jq -r '.intent // empty' "$law_json" 2>/dev/null)

# Determine title
title="${custom_title:-$law_title}"
if [[ -z "$title" ]]; then
    # Convert kebab-case to title case
    title=$(echo "$law_name" | sed 's/-/ /g' | sed 's/\b\(.\)/\u\1/g')
fi

# Build files array
files_json="["

# Add guidance.md if exists
if [[ -f "$guidance" ]]; then
    guidance_content=$(cat "$guidance" | jq -Rs .)
    files_json+="{\"path\":\"$law_name/guidance.md\",\"content\":$guidance_content},"
fi

# Add verify.sh if exists
if [[ -f "$verify" ]]; then
    verify_content=$(cat "$verify" | jq -Rs .)
    files_json+="{\"path\":\"$law_name/verify.sh\",\"content\":$verify_content},"
fi

# Add law.json (server expects string content for all files)
law_json_content=$(cat "$law_json" | jq -Rs .)
files_json+="{\"path\":\"$law_name/law.json\",\"content\":$law_json_content}"

files_json+="]"

# Build request body
body="{"
body+="\"title\":\"$title\","

# Add description
description="${custom_description:-$law_intent}"
if [[ -n "$description" ]]; then
    desc_escaped=$(echo "$description" | jq -Rs .)
    body+="\"description\":$desc_escaped,"
fi

# Add tags
if [[ -n "$custom_tags" ]]; then
    tags_array="["
    IFS=',' read -ra TAGS <<< "$custom_tags"
    for tag in "${TAGS[@]}"; do
        tag=$(echo "$tag" | xargs)
        tags_array+="\"$tag\","
    done
    tags_array="${tags_array%,}]"
    body+="\"tags\":$tags_array,"
fi

# Add author
if [[ -n "$custom_author" ]]; then
    body+="\"authorName\":\"$custom_author\","
fi

# Add files
body+="\"files\":$files_json"
body+="}"

[[ -n "$verbose" ]] && echo "Request body:" && echo "$body" | jq . && echo ""

# Dry run - just show payload
if [[ -n "$dry_run" ]]; then
    echo "Dry run - would upload the following:"
    echo ""
    echo "$body" | jq .
    echo ""
    echo "Add --dry-run=false to actually upload"
    exit 0
fi

# Upload to marketplace
echo "Publishing to marketplace..."
echo "  Title: $title"
echo "  Law: $law_name"
echo ""

response=$(curl -s -X POST "$MARKETPLACE_API/statues" \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d "$body")

# Check for errors
error=$(echo "$response" | jq -r '.error // empty' 2>/dev/null)

if [[ -n "$error" ]]; then
    echo "Error: $error" >&2
    echo "" >&2
    echo "Response:" >&2
    echo "$response" | jq . >&2
    exit 1
fi

# Success
slug=$(echo "$response" | jq -r '.slug // empty' 2>/dev/null)

if [[ -z "$slug" ]]; then
    echo "Error: unexpected response from server" >&2
    echo "$response" | jq . >&2
    exit 1
fi

echo "Published successfully!"
echo ""
echo "  Slug: $slug"
echo "  URL: https://pinkdonut.work/laws/$slug"
echo ""
echo "Search with: chp search \"$title\""
