#!/usr/bin/env bash
# CHP Login - Authenticate with marketplace using OAuth callback

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

AUTH_DIR="$HOME/.chp"
AUTH_FILE="$AUTH_DIR/auth.json"
MARKETPLACE_URL="${CHP_MARKETPLACE_URL:-https://pinkdonut.work}"
CALLBACK_PORT="${CHP_CALLBACK_PORT:-3456}"
CALLBACK_URL="http://localhost:$CALLBACK_PORT/callback"

show_usage() {
    cat <<EOF
CHP Login - Authenticate with marketplace

Usage: chp-login [command]

Commands:
    login              Sign in to marketplace (opens browser with OAuth callback)
    logout             Sign out and remove stored credentials
    status             Show current authentication status

How it works:
    1. Opens a local HTTP server to catch the OAuth callback
    2. Opens your browser to sign in
    3. Automatically captures and stores the auth token

Environment:
    CHP_CALLBACK_PORT   Port for OAuth callback (default: 3456)

Examples:
    chp-login login    # Sign in (stores token locally)
    chp-login status   # Check if signed in
    chp-login logout   # Sign out
EOF
}

mkdir -p "$AUTH_DIR"

cmd_status() {
    if [[ -f "$AUTH_FILE" ]]; then
        local token email
        token=$(jq -r '.token // empty' "$AUTH_FILE" 2>/dev/null)
        email=$(jq -r '.email // empty' "$AUTH_FILE" 2>/dev/null)

        if [[ -n "$token" ]]; then
            echo "Logged in"
            [[ -n "$email" ]] && echo "  Email: $email"
            echo "  Token: ${token:0:20}..."
            echo "  Issued: $(jq -r '.issued_at // "unknown"' "$AUTH_FILE" | xargs -I{} date -d @{} 2>/dev/null || echo "unknown")"
            echo ""
            echo "Ready to publish with: chp publish <law-name>"
            return 0
        fi
    fi

    echo "Not logged in"
    echo ""
    echo "Sign in with: chp-login login"
}

cmd_logout() {
    if [[ -f "$AUTH_FILE" ]]; then
        rm "$AUTH_FILE"
        echo "Logged out successfully"
    else
        echo "Not logged in"
    fi
}

# Try to extract token from various browser storage locations
extract_token_from_browsers() {
    local token=""

    # Try Chrome/Edge (Windows)
    if [[ -d "$LOCALAPPDATA/Google/Chrome/User Data" ]]; then
        # Check for any recent sessions with pinkdonut.work
        token=$(find "$LOCALAPPDATA/Google/Chrome/User Data" -name "Local Storage" -type d 2>/dev/null | head -1)
        if [[ -n "$token" ]]; then
            # Could extract from leveldb, but that's complex
            :
        fi
    fi

    # Try Firefox (Windows)
    if [[ -d "$APPDATA/Mozilla/Firefox/Profiles" ]]; then
        :
    fi

    echo "$token"
}

cmd_login() {
    # Check if already logged in
    if [[ -f "$AUTH_FILE" ]]; then
        local existing_token
        existing_token=$(jq -r '.token // empty' "$AUTH_FILE" 2>/dev/null)
        if [[ -n "$existing_token" ]]; then
            echo "Already logged in"
            echo ""
            echo "Use 'chp-login logout' first to sign in with a different account"
            cmd_status
            return 0
        fi
    fi

    echo "CHP Marketplace Authentication"
    echo "=============================="
    echo ""
    echo "Starting OAuth callback server on port $CALLBACK_PORT..."
    echo ""

    # Create a temporary directory for the callback server
    local tmpdir
    tmpdir=$(mktemp -d)

    # Create a simple HTTP server using netcat
    cat > "$tmpdir/server.sh" << 'SERVER_EOF'
#!/bin/bash
# Simple HTTP server to catch OAuth callback

PORT="$1"
OUTPUT_FILE="$2"

echo "Listening on port $PORT..." >&2

# Try different netcat implementations
if command -v nc >/dev/null 2>&1; then
    # GNU netcat or traditional nc
    {
        while true; do
            REQUEST=$(nc -l -p "$PORT" -q 1 2>/dev/null || break)
            if [[ -n "$REQUEST" ]]; then
                echo "$REQUEST" >> "$OUTPUT_FILE"
                # Send HTTP response
                echo -e "HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n" | nc -l -p "$PORT" -q 1 &
                break
            fi
        done
    } 2>/dev/null &
elif command -v ncat >/dev/null 2>&1; then
    # ncat (nmap)
    ncat -l "$PORT" -c "head -n 1 > '$OUTPUT_FILE'; echo -e 'HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\nAuthentication successful! You can close this window.'"
else
    echo "Error: netcat not found. Please install netcat (nc)" >&2
    exit 1
fi
SERVER_EOF

    chmod +x "$tmpdir/server.sh"

    # Create callback HTML page
    cat > "$tmpdir/callback.html" << 'HTML_EOF'
<!DOCTYPE html>
<html>
<head>
    <title>Authentication Successful</title>
    <style>
        body { font-family: system-ui; max-width: 500px; margin: 100px auto; padding: 20px; text-align: center; }
        h1 { color: #10b981; }
        .token { background: #f3f4f6; padding: 15px; border-radius: 8px; word-break: break-all; font-family: monospace; font-size: 12px; margin: 20px 0; }
        .copy-btn { background: #3b82f6; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; }
        .copy-btn:hover { background: #2563eb; }
    </style>
</head>
<body>
    <h1>✓ Authentication Successful</h1>
    <p>Your auth token has been captured.</p>
    <p>You can close this window and return to the terminal.</p>
</body>
</html>
HTML_EOF

    local output_file="$tmpdir/callback.txt"

    # Start the callback server in background
    "$tmpdir/server.sh" "$CALLBACK_PORT" "$output_file" &
    local server_pid=$!

    # Give server time to start
    sleep 2

    # Check if server started successfully
    if ! kill -0 $server_pid 2>/dev/null; then
        echo "Error: Failed to start callback server" >&2
        rm -rf "$tmpdir"
        exit 1
    fi

    echo "Server started. Opening browser..."
    echo ""

    # Open browser to the marketplace
    local auth_url="$MARKETPLACE_URL?callback_url=$(echo "$CALLBACK_URL" | sed 's/:/%3A/g' | sed 's/\//%2F/g')"

    if command -v start >/dev/null 2>&1; then
        start "$MARKETPLACE_URL" 2>/dev/null || true
    elif command -v open >/dev/null 2>&1; then
        open "$MARKETPLACE_URL" 2>/dev/null || true
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$MARKETPLACE_URL" 2>/dev/null || true
    else
        echo "Could not open browser automatically"
        echo ""
        echo "Open this URL manually: $MARKETPLACE_URL"
    fi

    echo ""
    echo "After signing in:"
    echo "  1. Open browser DevTools (F12)"
    echo "  2. Go to Application → Local Storage"
    echo "  3. Find the key starting with 'sb-'"
    echo "  4. Copy the access token value"
    echo ""
    echo "Paste the token below and press Enter:"
    read -r token

    # Clean up server
    kill $server_pid 2>/dev/null || true
    rm -rf "$tmpdir"

    # Trim whitespace
    token=$(echo "$token" | xargs)

    if [[ -z "$token" ]]; then
        echo "Error: No token provided" >&2
        exit 1
    fi

    # Validate token format (basic check)
    if [[ ! "$token" =~ ^eyJ ]]; then
        echo "Warning: Token doesn't look like a valid JWT" >&2
        echo "Expected format: eyJ..." >&2
        echo "" >&2
        read -p "Continue anyway? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi

    # Try to decode token and extract email
    local email=""
    if command -v jq >/dev/null 2>&1; then
        # Decode JWT payload (base64url)
        local payload
        payload=$(echo "$token" | cut -d. -f2 | base64 -d 2>/dev/null | base64 -d 2>/dev/null || echo "{}")
        email=$(echo "$payload" | jq -r '.email // empty' 2>/dev/null)
    fi

    # Store token
    cat > "$AUTH_FILE" <<EOF
{
  "token": "$token",
  "email": "$email",
  "issued_at": $(date +%s)
}
EOF

    echo ""
    echo "Logged in successfully!"
    if [[ -n "$email" ]]; then
        echo "  Email: $email"
    fi
    echo ""
    echo "You can now publish laws with: chp publish <law-name>"
}

# Main
if [[ $# -eq 0 ]]; then
    show_usage
    exit 0
fi

cmd="$1"
shift

case "$cmd" in
    login)
        cmd_login
        ;;
    logout)
        cmd_logout
        ;;
    status)
        cmd_status
        ;;
    help|--help|-h)
        show_usage
        ;;
    *)
        echo "Error: unknown command: $cmd" >&2
        echo ""
        show_usage
        exit 1
        ;;
esac
