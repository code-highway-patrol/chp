#!/usr/bin/env bash
# CHP Login - Authenticate with marketplace via browser OAuth handshake

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"

AUTH_DIR="$HOME/.chp"
AUTH_FILE="$AUTH_DIR/auth.json"
MARKETPLACE_URL="${CHP_MARKETPLACE_URL:-https://pinkdonut.work}"
MARKETPLACE_API="${CHP_MARKETPLACE_API:-$MARKETPLACE_URL/api}"
POLL_INTERVAL="${CHP_LOGIN_POLL_INTERVAL:-2}"
POLL_TIMEOUT="${CHP_LOGIN_POLL_TIMEOUT:-300}"

show_usage() {
    cat <<EOF
CHP Login - Authenticate with marketplace

Usage: chp-login [command]

Commands:
    login              Sign in via browser (OAuth handshake)
    logout             Sign out and remove stored credentials
    status             Show current authentication status

Environment:
    CHP_MARKETPLACE_URL       Marketplace web origin (default: https://pinkdonut.work)
    CHP_MARKETPLACE_API       Marketplace API base (default: \$CHP_MARKETPLACE_URL/api)
    CHP_LOGIN_POLL_INTERVAL   Seconds between poll attempts (default: 2)
    CHP_LOGIN_POLL_TIMEOUT    Total seconds to wait for authorization (default: 300)
EOF
}

mkdir -p "$AUTH_DIR"
chmod 700 "$AUTH_DIR" 2>/dev/null || true

require_dep() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Error: '$1' is required but not installed" >&2
        exit 1
    fi
}

cmd_status() {
    if [[ -f "$AUTH_FILE" ]]; then
        local token email expires_at
        token=$(jq -r '.token // empty' "$AUTH_FILE" 2>/dev/null)
        email=$(jq -r '.email // empty' "$AUTH_FILE" 2>/dev/null)
        expires_at=$(jq -r '.expires_at // empty' "$AUTH_FILE" 2>/dev/null)

        if [[ -n "$token" ]]; then
            echo "Logged in"
            [[ -n "$email" ]] && echo "  Email: $email"
            echo "  Token: ${token:0:20}..."
            if [[ -n "$expires_at" && "$expires_at" != "null" ]]; then
                local now diff
                now=$(date +%s)
                diff=$((expires_at - now))
                if (( diff > 0 )); then
                    echo "  Expires in: $((diff / 60))m"
                else
                    echo "  Expired (run: chp login)"
                fi
            fi
            echo ""
            echo "Ready to publish with: chp publish <law-name>"
            return 0
        fi
    fi

    echo "Not logged in"
    echo ""
    echo "Sign in with: chp login"
}

cmd_logout() {
    if [[ -f "$AUTH_FILE" ]]; then
        rm -f "$AUTH_FILE"
        echo "Logged out"
    else
        echo "Not logged in"
    fi
}

open_browser() {
    local url="$1"
    if command -v open >/dev/null 2>&1; then
        open "$url" >/dev/null 2>&1 && return 0
    fi
    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" >/dev/null 2>&1 && return 0
    fi
    if command -v start >/dev/null 2>&1; then
        start "$url" >/dev/null 2>&1 && return 0
    fi
    return 1
}

cmd_login() {
    require_dep curl
    require_dep jq
    require_dep openssl

    if [[ -f "$AUTH_FILE" ]]; then
        local existing
        existing=$(jq -r '.token // empty' "$AUTH_FILE" 2>/dev/null)
        if [[ -n "$existing" ]]; then
            echo "Already logged in. Run 'chp login logout' first to switch accounts."
            cmd_status
            return 0
        fi
    fi

    local verifier verifier_hash start_response code verification_url
    verifier=$(openssl rand -hex 32)
    verifier_hash=$(printf '%s' "$verifier" | openssl dgst -sha256 -hex 2>/dev/null | awk '{print $NF}')
    if [[ -z "$verifier_hash" ]]; then
        echo "Error: failed to compute verifier hash" >&2
        exit 1
    fi

    start_response=$(curl -sS -X POST "$MARKETPLACE_API/cli-auth/start" \
        -H "Content-Type: application/json" \
        -d "{\"verifier_hash\":\"$verifier_hash\"}") || {
        echo "Error: could not reach $MARKETPLACE_API/cli-auth/start" >&2
        exit 1
    }

    code=$(echo "$start_response" | jq -r '.code // empty')
    verification_url=$(echo "$start_response" | jq -r '.verification_url // empty')
    if [[ -z "$code" || -z "$verification_url" ]]; then
        echo "Error: unexpected response from server" >&2
        echo "$start_response" >&2
        exit 1
    fi

    echo "CHP Marketplace Authentication"
    echo "=============================="
    echo ""
    echo "Opening browser to authorize this CLI..."
    echo "  $verification_url"
    echo ""

    if ! open_browser "$verification_url"; then
        echo "Could not open a browser automatically."
        echo "Open this URL manually to continue:"
        echo "  $verification_url"
    fi

    echo ""
    echo "Waiting for authorization (timeout: ${POLL_TIMEOUT}s)..."

    local elapsed=0 status http_code body

    while (( elapsed < POLL_TIMEOUT )); do
        sleep "$POLL_INTERVAL"
        elapsed=$((elapsed + POLL_INTERVAL))

        local poll_url="$MARKETPLACE_API/cli-auth/poll?code=$code&verifier=$verifier"
        local tmp
        tmp=$(mktemp -t chp-login.XXXXXX)
        http_code=$(curl -sS -o "$tmp" -w "%{http_code}" "$poll_url" || echo "000")
        body=$(cat "$tmp")
        rm -f "$tmp"

        case "$http_code" in
            200)
                status=$(echo "$body" | jq -r '.status // empty')
                if [[ "$status" == "completed" ]]; then
                    local token email refresh expires_at
                    token=$(echo "$body" | jq -r '.access_token // empty')
                    email=$(echo "$body" | jq -r '.email // empty')
                    refresh=$(echo "$body" | jq -r '.refresh_token // empty')
                    expires_at=$(echo "$body" | jq -r '.expires_at // empty')

                    if [[ -z "$token" ]]; then
                        echo "Error: server returned completed but no token" >&2
                        exit 1
                    fi

                    jq -n \
                        --arg token "$token" \
                        --arg email "$email" \
                        --arg refresh "$refresh" \
                        --arg expires "$expires_at" \
                        --argjson issued "$(date +%s)" \
                        '{
                            token: $token,
                            email: ($email | select(. != "")),
                            refresh_token: ($refresh | select(. != "")),
                            expires_at: ($expires | select(. != "" and . != "null") | tonumber? // null),
                            issued_at: $issued
                        } | with_entries(select(.value != null))' > "$AUTH_FILE"
                    chmod 600 "$AUTH_FILE" 2>/dev/null || true

                    echo ""
                    echo "Logged in successfully."
                    [[ -n "$email" ]] && echo "  Signed in as: $email"
                    echo ""
                    echo "Publish a law with: chp publish <law-name>"
                    return 0
                fi
                ;;
            202)
                printf '.'
                ;;
            403)
                echo ""
                echo "Error: verifier mismatch (the browser session does not match this CLI)" >&2
                exit 1
                ;;
            404)
                echo ""
                echo "Error: authorization code expired or was rejected" >&2
                exit 1
                ;;
            410)
                echo ""
                echo "Error: authorization code expired before approval" >&2
                exit 1
                ;;
            *)
                echo ""
                echo "Warning: unexpected response (HTTP $http_code), retrying..."
                ;;
        esac
    done

    echo ""
    echo "Error: authorization timed out after ${POLL_TIMEOUT}s" >&2
    echo "Run 'chp login' again to retry." >&2
    exit 1
}

if [[ $# -eq 0 ]]; then
    cmd_login
    exit 0
fi

cmd="$1"
shift

case "$cmd" in
    login)
        cmd_login
        ;;
    logout)
        cmd_logout
        ;;
    status)
        cmd_status
        ;;
    help|--help|-h)
        show_usage
        ;;
    *)
        echo "Error: unknown command: $cmd" >&2
        echo ""
        show_usage
        exit 1
        ;;
esac
