#!/bin/bash
# CHP Law Management Command
# Main CLI for creating, listing, deleting, testing, and resetting laws

# Source core functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"
source "$SCRIPT_DIR/../core/detector.sh"
source "$SCRIPT_DIR/../core/installer.sh"
source "$SCRIPT_DIR/../core/tightener.sh"

# Display usage information
show_usage() {
    cat <<EOF
CHP Law Management System

Usage:
    chp-law <command> [options]

Commands:
    create <law-name> [--hooks=<hook1,hook2>]  Create a new law
    list                                      List all laws
    delete <law-name>                         Delete a law and uninstall hooks
    test <law-name>                           Test a law's verification script
    reset <law-name>                          Reset failure count for a law
    disable <law-name>                        Disable a law (keep but don't enforce)
    enable <law-name>                         Enable a disabled law
    help                                      Show this help message

Options:
    --hooks=<hooks>    Comma-separated list of hooks to install (e.g., pre-commit,pre-push)

Examples:
    chp-law create no-debug-code --hooks=pre-commit
    chp-law create test-coverage --hooks=pre-commit,pre-push
    chp-law list
    chp-law test no-debug-code
    chp-law reset no-debug-code
    chp-law disable no-debug-code
    chp-law enable no-debug-code

Law Naming Rules:
    - Only lowercase letters, numbers, and hyphens allowed
    - Must start with a lowercase letter
    - Minimum 3 characters, maximum 32 characters

EOF
}

# Validate law name format
validate_law_name() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    # Check length (3-32 characters)
    if [[ ${#law_name} -lt 3 || ${#law_name} -gt 32 ]]; then
        log_error "Law name must be between 3 and 32 characters"
        return 1
    fi

    # Check format (lowercase, numbers, hyphens only, must start with letter)
    if [[ ! "$law_name" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "Law name must start with a lowercase letter and contain only lowercase letters, numbers, and hyphens"
        return 1
    fi

    return 0
}

# Parse hooks argument
parse_hooks() {
    local hooks_arg="$1"
    local hooks=()

    if [[ -n "$hooks_arg" ]]; then
        # Convert comma-separated to array
        IFS=',' read -ra hooks <<< "$hooks_arg"
    fi

    printf '%s\n' "${hooks[@]}"
}

# Create a new law
create_law() {
    local law_name="$1"
    local hooks_arg="$2"

    # Validate law name
    if ! validate_law_name "$law_name"; then
        return 1
    fi

    # Check if law already exists
    if law_exists "$law_name"; then
        log_error "Law already exists: $law_name"
        return 1
    fi

    # Parse hooks
    local hooks=()
    if [[ -n "$hooks_arg" ]]; then
        IFS=',' read -ra hooks <<< "$hooks_arg"
    fi

    # Create law directory
    local law_dir="$LAWS_DIR/$law_name"
    mkdir -p "$law_dir"

    log_info "Creating law: $law_name"

    # Create law.json with metadata
    cat > "$law_dir/law.json" <<EOF
{
  "name": "$law_name",
  "created": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "severity": "error",
  "failures": 0,
  "tightening_level": 0,
  "hooks": $(printf '%s\n' "${hooks[@]}" | jq -R . | jq -s -c .),
  "enabled": true
}
EOF

    # Create verify.sh (verification script template)
    cat > "$law_dir/verify.sh" <<EOF
#!/bin/bash
# Verification script for law: $law_name

# Get the absolute path to CHP base directory
LAW_DIR="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
CHP_BASE="\$(cd "\$LAW_DIR/../../../../" && pwd)"

# Source CHP common functions
source "\$CHP_BASE/core/common.sh"

# Main verification logic
verify_law() {
    local law_name="$law_name"

    log_info "Verifying law: $law_name"

    # Add your verification logic here
    # Return 0 if verification passes
    # Return 1 if verification fails

    # Example: Check for debug statements
    if git diff --cached --name-only | grep -q '\.js$\|\.ts$\|\.py$'; then
        if git diff --cached | grep -i 'console\.debug\|debugger'; then
            log_error "Debug statements found in staged files"
            return 1
        fi
    fi

    log_info "Law verification passed: $law_name"
    return 0
}

# Run verification
verify_law
exit $?
EOF

    chmod +x "$law_dir/verify.sh"

    # Register law in hook registry
    source "$SCRIPT_DIR/../core/hook-registry.sh"
    init_hook_registry

    if [[ ${#hooks[@]} -gt 0 ]]; then
        for hook in "${hooks[@]}"; do
            hook=$(echo "$hook" | xargs)  # trim whitespace
            register_hook_law "$hook" "$law_name"
        done
        log_info "Registered '$law_name' with hooks: $(IFS=', '; echo "${hooks[*]}")"
    fi

    # Create guidance.md (guidance documentation template)
    cat > "$law_dir/guidance.md" <<EOF
# Law: $law_name

**Severity:** error
**Created:** $(date -u +"%Y-%m-%dT%H:%M:%SZ")
**Failures:** 0

## Purpose

This law enforces specific code quality or project standards.

## Guidance

Describe what this law checks for and how to comply.

### Examples

#### Good Practice
\`\`\`
// Show examples of compliant code
\`\`\`

#### Bad Practice (will fail verification)
\`\`\`
// Show examples of non-compliant code
\`\`\`

## Remediation

If this law fails, take these steps:
1. Identify the violation
2. Fix the issue
3. Re-run the verification
4. Commit your changes

---

*This guidance will be automatically strengthened if violations occur.*
EOF

    log_info "Created law directory: $law_dir"
    log_info "Created law.json: $law_dir/law.json"
    log_info "Created verify.sh: $law_dir/verify.sh"
    log_info "Created guidance.md: $law_dir/guidance.md"

    # Install hooks if specified
    if [[ ${#hooks[@]} -gt 0 ]]; then
        log_info "Installing hooks..."
        for hook in "${hooks[@]}"; do
            if install_hook "$law_name" "$hook"; then
                log_info "Installed hook: $hook"
            else
                log_warn "Failed to install hook: $hook"
            fi
        done
    else
        log_warn "No hooks specified. Use --hooks=pre-commit,pre-push to install hooks"
    fi

    log_info "Law created successfully: $law_name"
    log_info "Edit $law_dir/verify.sh to implement verification logic"
    log_info "Edit $law_dir/guidance.md to add compliance guidance"

    return 0
}

# List all laws
list_laws_cmd() {
    log_info "Listing all laws..."

    local law_count=0
    for law_dir in "$LAWS_DIR"/*; do
        if [ -d "$law_dir" ]; then
            law_count=$((law_count + 1))
            local name=$(basename "$law_dir")
            local severity=$(get_law_meta "$name" "severity")
            local failures=$(get_law_meta "$name" "failures")
            local enabled=$(get_law_meta "$name" "enabled")

            local status="enabled"
            if [[ "$enabled" == "false" ]]; then
                status="disabled"
            fi

            echo "  $name | severity: $severity | failures: $failures | $status"
        fi
    done

    if [[ $law_count -eq 0 ]]; then
        log_info "No laws found"
    else
        log_info "Total laws: $law_count"
    fi

    return 0
}

# Delete a law and uninstall hooks
delete_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Unregister from hook registry
    source "$SCRIPT_DIR/../core/hook-registry.sh"

    local hooks
    hooks=$(jq -r '.hooks[]? // empty' "$law_json" 2>/dev/null)
    if [[ -n "$hooks" ]]; then
        log_info "Unregistering from hook registry..."
        while IFS= read -r hook; do
            hook=$(echo "$hook" | tr -d '\r')  # handle Windows line endings
            unregister_hook_law "$hook" "$law_name"
            log_info "Unregistered '$law_name' from hook: $hook"
        done <<< "$hooks"
    fi

    # Get hooks from law.json for uninstall
    hooks=$(jq -r '.hooks[] // empty' "$law_json")

    # Uninstall hooks
    if [[ -n "$hooks" ]]; then
        log_info "Uninstalling hooks..."
        while IFS= read -r hook; do
            if uninstall_hook "$law_name" "$hook"; then
                log_info "Uninstalled hook: $hook"
            fi
        done <<< "$hooks"
    fi

    # Remove law directory
    rm -rf "$law_dir"
    log_info "Deleted law: $law_name"

    return 0
}

# Test a law's verification script
test_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local verify_script="$law_dir/verify.sh"

    if [[ ! -f "$verify_script" ]]; then
        log_error "Verification script not found: $verify_script"
        return 1
    fi

    log_info "Testing law: $law_name"
    log_info "Running verification script..."

    # Run the verification script
    if bash "$verify_script"; then
        log_info "Law verification passed: $law_name"
        return 0
    else
        local exit_code=$?
        log_error "Law verification failed: $law_name (exit code: $exit_code)"
        return $exit_code
    fi
}

# Reset failure count for a law
reset_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    log_info "Resetting law: $law_name"

    if reset_failures "$law_name"; then
        log_info "Law reset successfully: $law_name"
        return 0
    else
        log_error "Failed to reset law: $law_name"
        return 1
    fi
}

# Disable a law
disable_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Check if already disabled
    local enabled
    enabled=$(get_law_meta "$law_name" "enabled")

    if [[ "$enabled" == "false" ]]; then
        log_info "Law already disabled: $law_name"
        return 0
    fi

    # Update law.json to set enabled=false
    jq '.enabled = false' "$law_json" > "${law_json}.tmp" && \
    mv "${law_json}.tmp" "$law_json"

    log_info "Law disabled successfully: $law_name"

    return 0
}

# Enable a law
enable_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Check if already enabled
    local enabled
    enabled=$(get_law_meta "$law_name" "enabled")

    if [[ "$enabled" == "true" ]]; then
        log_info "Law already enabled: $law_name"
        return 0
    fi

    # Update law.json to set enabled=true
    jq '.enabled = true' "$law_json" > "${law_json}.tmp" && \
    mv "${law_json}.tmp" "$law_json"

    log_info "Law enabled successfully: $law_name"

    return 0
}

# Main command routing
main() {
    local command="$1"
    shift

    case "$command" in
        create)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law create <law-name> [--hooks=<hooks>]"
                exit 1
            fi
            local law_name="$1"
            local hooks_arg=""
            shift

            # Parse optional hooks argument
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --hooks=*)
                        hooks_arg="${1#*=}"
                        ;;
                    *)
                        log_error "Unknown option: $1"
                        exit 1
                        ;;
                esac
                shift
            done

            create_law "$law_name" "$hooks_arg"
            ;;
        list)
            list_laws_cmd
            ;;
        delete)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law delete <law-name>"
                exit 1
            fi
            delete_law "$1"
            ;;
        test)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law test <law-name>"
                exit 1
            fi
            test_law "$1"
            ;;
        reset)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law reset <law-name>"
                exit 1
            fi
            reset_law "$1"
            ;;
        disable)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law disable <law-name>"
                exit 1
            fi
            disable_law "$1"
            ;;
        enable)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law enable <law-name>"
                exit 1
            fi
            enable_law "$1"
            ;;
        help|--help|-h)
            show_usage
            ;;
        "")
            log_error "No command specified"
            show_usage
            exit 1
            ;;
        *)
            log_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

# Run main
main "$@"
