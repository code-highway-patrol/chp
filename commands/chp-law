#!/bin/bash
# CHP Law Management Command
# Main CLI for creating, listing, deleting, testing, and resetting laws

# Source core functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"
source "$SCRIPT_DIR/../core/detector.sh"
source "$SCRIPT_DIR/../core/installer.sh"
source "$SCRIPT_DIR/../core/tightener.sh"

# Source interactive and builder modules
source "$SCRIPT_DIR/../core/interactive.sh"
source "$SCRIPT_DIR/../core/law-builder.sh"

# Display usage information
show_usage() {
    cat <<EOF
CHP Law Management System

Usage:
    chp-law <command> [options]

Commands:
    create <law-name> [--hooks=<hook1,hook2>] [--dry-run] [--response=<text>]...  Create a new law
    update <law-name> [options]               Update law configuration
    list                                      List all laws
    delete <law-name>                         Delete a law and uninstall hooks
    test <law-name>                           Test a law's verification script
    reset <law-name>                          Reset failure count for a law
    disable <law-name>                        Disable a law (keep but don't enforce)
    enable <law-name>                         Enable a disabled law
    help                                      Show this help message

Options:
    --hooks=<hooks>       Comma-separated list of hooks (e.g., pre-commit,pre-push)
    --severity=<level>    Severity level (error|warn|info)
    --pattern=<regex>     Custom detection pattern
    --files=<extensions>  File types to check (comma-separated)
    --exceptions=<list>   Exception patterns (comma-separated)
    --dry-run             Show preview without creating the law
    --response=<text>     Pre-answer interactive prompts (for testing)

Update Options:
    --severity=<level>         Change severity
    --hooks=<list>             Replace all hooks
    --add-hook=<hook>          Add a hook
    --remove-hook=<hook>       Remove a hook
    --add-exception=<pattern>  Add exception pattern (not yet implemented)
    --remove-exception=<pattern> Remove exception pattern (not yet implemented)
    --set-guidance             Open guidance.md for editing

Examples:
    chp-law create no-debug-code --hooks=pre-commit
    chp-law create test-coverage --hooks=pre-commit,pre-push
    chp-law create custom-law --response="Choose one: D" --response="Enter pattern: console.log"
    chp-law update no-debug-code --severity=error
    chp-law update test-coverage --add-hook=pre-push
    chp-law update no-debug-code --set-guidance
    chp-law list
    chp-law test no-debug-code
    chp-law reset no-debug-code
    chp-law disable no-debug-code
    chp-law enable no-debug-code

Law Naming Rules:
    - Only lowercase letters, numbers, and hyphens allowed
    - Must start with a lowercase letter
    - Minimum 3 characters, maximum 32 characters

EOF
}

# Validate law name format
validate_law_name() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    # Check length (3-32 characters)
    if [[ ${#law_name} -lt 3 || ${#law_name} -gt 32 ]]; then
        log_error "Law name must be between 3 and 32 characters"
        return 1
    fi

    # Check format (lowercase, numbers, hyphens only, must start with letter)
    if [[ ! "$law_name" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "Law name must start with a lowercase letter and contain only lowercase letters, numbers, and hyphens"
        return 1
    fi

    return 0
}

# Parse hooks argument
parse_hooks() {
    local hooks_arg="$1"
    local hooks=()

    if [[ -n "$hooks_arg" ]]; then
        # Convert comma-separated to array
        IFS=',' read -ra hooks <<< "$hooks_arg"
    fi

    printf '%s\n' "${hooks[@]}"
}

# Create a new law
create_law() {
    local law_name="$1"
    local hooks_arg="$2"
    local dry_run=false

    # Response queue for pre-answered prompts
    declare -a RESPONSE_QUEUE=()

    # Flag variables (from command line or interactive)
    local specified_severity=""
    local specified_pattern=""
    local specified_files=""
    local specified_exceptions=""

    # Parse optional arguments
    shift 2
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=true
                ;;
            --response=*)
                RESPONSE_QUEUE+=("${1#*=}")
                ;;
            --severity=*)
                specified_severity="${1#*=}"
                ;;
            --pattern=*)
                specified_pattern="${1#*=}"
                ;;
            --files=*)
                specified_files="${1#*=}"
                ;;
            --exceptions=*)
                specified_exceptions="${1#*=}"
                ;;
            *)
                log_error "Unknown option: $1"
                return 1
                ;;
        esac
        shift
    done

    # Validate law name
    if ! validate_law_name "$law_name"; then
        return 1
    fi

    # Check if law already exists
    if law_exists "$law_name"; then
        log_error "Law already exists: $law_name"
        return 1
    fi

    # Parse hooks
    local hooks=()
    if [[ -n "$hooks_arg" ]]; then
        IFS=',' read -ra hooks <<< "$hooks_arg"
    fi

    # Create law directory
    local law_dir="$LAWS_DIR/$law_name"

    log_info "Creating law: $law_name"

    # Determine if intent is clear
    local severity
    local pattern
    local files
    local exceptions

    if is_intent_clear "$law_name"; then
        # Suggest configuration (call once and parse all 5 output lines)
        local config output_array
        mapfile -t output_array < <(suggest_config "$law_name")

        # Read all 5 values from suggest_config output (each on its own line)
        local severity="${output_array[0]}"
        local hooks_pattern="${output_array[1]}"
        local pattern="${output_array[2]}"
        local files="${output_array[3]}"
        local exceptions="${output_array[4]}"

        # Convert comma-separated hooks to array (if not already set via --hooks)
        if [[ ${#hooks[@]} -eq 0 && -n "$hooks_pattern" ]]; then
            IFS=',' read -ra hooks <<< "$hooks_pattern"
        fi
    else
        # Ask questions interactively (or use pre-configured responses)
        echo "Creating law: $law_name"
        echo ""
        echo "What should this law enforce?"
        echo "  A) File size limits"
        echo "  B) Function length limits"
        echo "  C) Documentation requirements"
        echo "  D) Custom pattern"

        local choice
        if [[ ${#RESPONSE_QUEUE[@]} -gt 0 ]]; then
            choice="${RESPONSE_QUEUE[0]}"
            RESPONSE_QUEUE=("${RESPONSE_QUEUE[@]:1}")
            echo "Choose one: $choice"
        else
            read -p "Choose one: " choice
        fi

        case "$choice" in
            A|a)
                pattern="File line count > LIMIT"
                files="All source files"
                ;;
            B|b)
                pattern="Function line count > LIMIT"
                files="*.js,*.ts,*.py"
                ;;
            C|c)
                pattern="(TODO|FIXME)"
                files="All source files"
                ;;
            *)
                if [[ ${#RESPONSE_QUEUE[@]} -gt 0 ]]; then
                    pattern="${RESPONSE_QUEUE[0]}"
                    RESPONSE_QUEUE=("${RESPONSE_QUEUE[@]:1}")
                    echo "Enter the pattern to detect: $pattern"
                else
                    pattern=$(prompt_text "Enter the pattern to detect")
                fi

                if [[ ${#RESPONSE_QUEUE[@]} -gt 0 ]]; then
                    files="${RESPONSE_QUEUE[0]}"
                    RESPONSE_QUEUE=("${RESPONSE_QUEUE[@]:1}")
                    echo "Which file types: $files"
                else
                    files=$(prompt_text "Which file types" "*.js,*.ts")
                fi
                ;;
        esac

        severity="warn"
        hooks="pre-commit"
        exceptions="none"
    fi

    # Apply flag overrides if provided
    [[ -n "$specified_severity" ]] && severity="$specified_severity"
    [[ -n "$specified_pattern" ]] && pattern="$specified_pattern"
    [[ -n "$specified_files" ]] && files="$specified_files"
    [[ -n "$specified_exceptions" ]] && exceptions="$specified_exceptions"

    # Show preview (convert hooks array to comma-separated string)
    local hooks_str
    if [[ ${#hooks[@]} -gt 0 ]]; then
        # Join array elements with comma
        hooks_str=$(IFS=','; echo "${hooks[*]}")
    else
        hooks_str=""
    fi
    display_preview "$law_name" "$severity" "$hooks_str" "$pattern" "$files" "$exceptions"

    # Confirm before creating (unless dry-run or response provided)
    if [[ "$dry_run" = true ]]; then
        log_info "Dry run - law not created"
        return 0
    fi

    local confirmed=false
    if [[ ${#RESPONSE_QUEUE[@]} -gt 0 ]]; then
        local response="${RESPONSE_QUEUE[0]}"
        RESPONSE_QUEUE=("${RESPONSE_QUEUE[@]:1}")
        if [[ "$response" =~ ^[Yy]([Ee][Ss])?$ ]]; then
            confirmed=true
        fi
    else
        if prompt_yes_no "Create this law?"; then
            confirmed=true
        fi
    fi

    if [[ "$confirmed" = false ]]; then
        log_info "Law creation cancelled"
        return 0
    fi

    # Create law directory
    mkdir -p "$law_dir"

    # Create law.json with metadata
    cat > "$law_dir/law.json" <<EOF
{
  "name": "$law_name",
  "created": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "severity": "$severity",
  "failures": 0,
  "tightening_level": 0,
  "hooks": $(printf '%s\n' "${hooks[@]}" | jq -R . | jq -s -c .),
  "enabled": true
}
EOF

    # Create verify.sh (verification script template)
    cat > "$law_dir/verify.sh" <<EOF
#!/bin/bash
# Verification script for law: $law_name

# Get the absolute path to CHP base directory
LAW_DIR="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
CHP_BASE="\$(cd "\$LAW_DIR/../../../../" && pwd)"

# Source CHP common functions
source "\$CHP_BASE/core/common.sh"

# Main verification logic
verify_law() {
    local law_name="$law_name"

    log_info "Verifying law: $law_name"

    # Add your verification logic here
    # Return 0 if verification passes
    # Return 1 if verification fails

    # Example: Check for debug statements
    if git diff --cached --name-only | grep -q '\.js$\|\.ts$\|\.py$'; then
        if git diff --cached | grep -i 'console\.debug\|debugger'; then
            log_error "Debug statements found in staged files"
            return 1
        fi
    fi

    log_info "Law verification passed: $law_name"
    return 0
}

# Run verification
verify_law
exit $?
EOF

    chmod +x "$law_dir/verify.sh"

    # Register law in hook registry
    source "$SCRIPT_DIR/../core/hook-registry.sh"
    init_hook_registry

    if [[ ${#hooks[@]} -gt 0 ]]; then
        for hook in "${hooks[@]}"; do
            hook=$(echo "$hook" | xargs)  # trim whitespace
            register_hook_law "$hook" "$law_name"
        done
        log_info "Registered '$law_name' with hooks: $(IFS=', '; echo "${hooks[*]}")"
    fi

    # Create guidance.md (guidance documentation template)
    cat > "$law_dir/guidance.md" <<EOF
# Law: $law_name

**Severity:** $severity
**Created:** $(date -u +"%Y-%m-%dT%H:%M:%SZ")
**Failures:** 0

## Purpose

This law enforces specific code quality or project standards.

## Guidance

Describe what this law checks for and how to comply.

### Examples

#### Good Practice
\`\`\`
// Show examples of compliant code
\`\`\`

#### Bad Practice (will fail verification)
\`\`\`
// Show examples of non-compliant code
\`\`\`

## Remediation

If this law fails, take these steps:
1. Identify the violation
2. Fix the issue
3. Re-run the verification
4. Commit your changes

---

*This guidance will be automatically strengthened if violations occur.*
EOF

    log_info "Created law directory: $law_dir"
    log_info "Created law.json: $law_dir/law.json"
    log_info "Created verify.sh: $law_dir/verify.sh"
    log_info "Created guidance.md: $law_dir/guidance.md"

    # Install hooks if specified (using category-aware installer)
    if [[ ${#hooks[@]} -gt 0 ]]; then
        log_info "Installing hooks..."
        local has_agent_hooks=false
        for hook in "${hooks[@]}"; do
            hook=$(echo "$hook" | xargs)  # trim whitespace
            local hook_category
            hook_category=$(get_hook_category "$hook")

            if [[ "$hook_category" == "unknown" ]]; then
                log_warn "Unknown hook type: $hook (skipping)"
                continue
            fi

            if install_hook_template "$hook" "$hook_category"; then
                log_info "Installed $hook_category hook: $hook"
            else
                log_warn "Failed to install $hook_category hook: $hook"
            fi

            if [[ "$hook_category" == "agent" ]]; then
                has_agent_hooks=true
            fi
        done

        # Auto-configure Claude Code settings.json when agent hooks are used
        if [[ "$has_agent_hooks" == true ]]; then
            if command -v jq >/dev/null 2>&1; then
                install_claude_hooks
            else
                log_warn "jq is required to configure Claude Code agent hooks (skipping settings.json)"
            fi
        fi

        # Ensure any previously registered hooks are also still installed
        ensure_hooks_installed
    else
        log_warn "No hooks specified. Use --hooks=pre-commit,pre-push to install hooks"
    fi

    log_info "Law created successfully: $law_name"
    log_info "Edit $law_dir/verify.sh to implement verification logic"
    log_info "Edit $law_dir/guidance.md to add compliance guidance"

    return 0
}

# List all laws
list_laws_cmd() {
    log_info "Listing all laws..."

    local law_count=0
    for law_dir in "$LAWS_DIR"/*; do
        if [ -d "$law_dir" ]; then
            law_count=$((law_count + 1))
            local name=$(basename "$law_dir")
            local severity=$(get_law_meta "$name" "severity")
            local failures=$(get_law_meta "$name" "failures")
            local enabled=$(get_law_meta "$name" "enabled")

            local status="enabled"
            if [[ "$enabled" == "false" ]]; then
                status="disabled"
            fi

            echo "  $name | severity: $severity | failures: $failures | $status"
        fi
    done

    if [[ $law_count -eq 0 ]]; then
        log_info "No laws found"
    else
        log_info "Total laws: $law_count"
    fi

    return 0
}

# Delete a law and uninstall hooks
delete_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Unregister from hook registry
    source "$SCRIPT_DIR/../core/hook-registry.sh"

    local hooks
    hooks=$(jq -r '.hooks[]? // empty' "$law_json" 2>/dev/null)
    if [[ -n "$hooks" ]]; then
        log_info "Unregistering from hook registry..."
        while IFS= read -r hook; do
            hook=$(echo "$hook" | tr -d '\r')  # handle Windows line endings
            unregister_hook_law "$hook" "$law_name"
            log_info "Unregistered '$law_name' from hook: $hook"
        done <<< "$hooks"
    fi

    # Get hooks from law.json for uninstall
    hooks=$(jq -r '.hooks[] // empty' "$law_json")

    # Uninstall hooks (using category-aware uninstaller)
    if [[ -n "$hooks" ]]; then
        log_info "Uninstalling hooks..."
        while IFS= read -r hook; do
            hook=$(echo "$hook" | tr -d '\r' | xargs)
            local hook_category
            hook_category=$(get_hook_category "$hook")

            if [[ "$hook_category" == "unknown" ]]; then
                log_warn "Unknown hook type: $hook (skipping uninstall)"
                continue
            fi

            if uninstall_hook_template "$hook" "$hook_category"; then
                log_info "Uninstalled $hook_category hook: $hook"
            fi
        done <<< "$hooks"
    fi

    # Remove law directory
    rm -rf "$law_dir"
    log_info "Deleted law: $law_name"

    return 0
}

# Test a law's verification script
test_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local verify_script="$law_dir/verify.sh"

    if [[ ! -f "$verify_script" ]]; then
        log_error "Verification script not found: $verify_script"
        return 1
    fi

    log_info "Testing law: $law_name"
    log_info "Running verification script..."

    # Run the verification script
    if bash "$verify_script"; then
        log_info "Law verification passed: $law_name"
        return 0
    else
        local exit_code=$?
        log_error "Law verification failed: $law_name (exit code: $exit_code)"
        return $exit_code
    fi
}

# Reset failure count for a law
reset_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    log_info "Resetting law: $law_name"

    if reset_failures "$law_name"; then
        log_info "Law reset successfully: $law_name"
        return 0
    else
        log_error "Failed to reset law: $law_name"
        return 1
    fi
}

# Disable a law
disable_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Check if already disabled
    local enabled
    enabled=$(get_law_meta "$law_name" "enabled")

    if [[ "$enabled" == "false" ]]; then
        log_info "Law already disabled: $law_name"
        return 0
    fi

    # Update law.json to set enabled=false
    jq '.enabled = false' "$law_json" > "${law_json}.tmp" && \
    mv "${law_json}.tmp" "$law_json"

    log_info "Law disabled successfully: $law_name"

    return 0
}

# Enable a law
enable_law() {
    local law_name="$1"

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Check if already enabled
    local enabled
    enabled=$(get_law_meta "$law_name" "enabled")

    if [[ "$enabled" == "true" ]]; then
        log_info "Law already enabled: $law_name"
        return 0
    fi

    # Update law.json to set enabled=true
    jq '.enabled = true' "$law_json" > "${law_json}.tmp" && \
    mv "${law_json}.tmp" "$law_json"

    log_info "Law enabled successfully: $law_name"

    return 0
}

# Update a law's configuration
update_law() {
    local law_name="$1"
    shift

    if [[ -z "$law_name" ]]; then
        log_error "Law name is required"
        echo "Usage: chp-law update <law-name> [options]"
        return 1
    fi

    if ! law_exists "$law_name"; then
        log_error "Law does not exist: $law_name"
        return 1
    fi

    local law_dir="$LAWS_DIR/$law_name"
    local law_json="$law_dir/law.json"

    # Parse update options
    local new_severity=""
    local new_hooks=""
    local add_hook=""
    local remove_hook=""
    local add_exception=""
    local remove_exception=""
    local set_guidance=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --severity=*)
                new_severity="${1#*=}"
                ;;
            --hooks=*)
                new_hooks="${1#*=}"
                ;;
            --add-hook=*)
                add_hook="${1#*=}"
                ;;
            --remove-hook=*)
                remove_hook="${1#*=}"
                ;;
            --add-exception=*)
                add_exception="${1#*=}"
                ;;
            --remove-exception=*)
                remove_exception="${1#*=}"
                ;;
            --set-guidance)
                set_guidance=true
                ;;
            *)
                log_error "Unknown option: $1"
                return 1
                ;;
        esac
        shift
    done

    # Apply updates
    local updated=false

    if [[ -n "$new_severity" ]]; then
        jq ".severity = \"$new_severity\"" "$law_json" > "${law_json}.tmp" && \
            mv "${law_json}.tmp" "$law_json"
        log_info "Updated severity to: $new_severity"
        updated=true
    fi

    if [[ -n "$new_hooks" ]]; then
        local hooks_array=$(echo "$new_hooks" | jq -R . | jq -s -c .)
        jq ".hooks = $hooks_array" "$law_json" > "${law_json}.tmp" && \
            mv "${law_json}.tmp" "$law_json"
        log_info "Updated hooks to: $new_hooks"
        updated=true
    fi

    if [[ -n "$add_hook" ]]; then
        jq ".hooks += [\"$add_hook\"]" "$law_json" > "${law_json}.tmp" && \
            mv "${law_json}.tmp" "$law_json"
        log_info "Added hook: $add_hook"
        updated=true
    fi

    if [[ -n "$remove_hook" ]]; then
        jq ".hooks -= [\"$remove_hook\"]" "$law_json" > "${law_json}.tmp" && \
            mv "${law_json}.tmp" "$law_json"
        log_info "Removed hook: $remove_hook"
        updated=true
    fi

    if [[ -n "$add_exception" ]]; then
        # Add to exceptions array in law.json (would need to be added to schema first)
        log_info "Would add exception: $add_exception (not yet implemented)"
        updated=true
    fi

    if [[ -n "$remove_exception" ]]; then
        log_info "Would remove exception: $remove_exception (not yet implemented)"
        updated=true
    fi

    if [[ "$set_guidance" = true ]]; then
        log_info "Opening guidance.md for editing..."
        "${EDITOR:-vim}" "$law_dir/guidance.md"
        updated=true
    fi

    if [[ "$updated" = false ]]; then
        log_warn "No updates specified"
        return 0
    fi

    log_info "Law updated: $law_name"
    return 0
}

# Main command routing
main() {
    local command="$1"
    shift

    case "$command" in
        create)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law create <law-name> [--hooks=<hooks>] [--dry-run] [--response=<text>]... [--severity=<severity>] [--pattern=<pattern>] [--files=<files>] [--exceptions=<exceptions>]"
                exit 1
            fi
            local law_name="$1"
            local hooks_arg=""
            shift

            # Parse --hooks argument separately (needed for create_law signature)
            local remaining_args=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --hooks=*)
                        hooks_arg="${1#*=}"
                        ;;
                    *)
                        remaining_args+=("$1")
                        ;;
                esac
                shift
            done

            # Pass all remaining arguments to create_law
            create_law "$law_name" "$hooks_arg" "${remaining_args[@]}"
            ;;
        list)
            list_laws_cmd
            ;;
        delete)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law delete <law-name>"
                exit 1
            fi
            delete_law "$1"
            ;;
        test)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law test <law-name>"
                exit 1
            fi
            test_law "$1"
            ;;
        reset)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law reset <law-name>"
                exit 1
            fi
            reset_law "$1"
            ;;
        disable)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law disable <law-name>"
                exit 1
            fi
            disable_law "$1"
            ;;
        enable)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law enable <law-name>"
                exit 1
            fi
            enable_law "$1"
            ;;
        update)
            if [[ $# -lt 1 ]]; then
                log_error "Usage: chp-law update <law-name> [options]"
                exit 1
            fi
            update_law "$@"
            ;;
        help|--help|-h)
            show_usage
            ;;
        "")
            log_error "No command specified"
            show_usage
            exit 1
            ;;
        *)
            log_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

# Run main
main "$@"
