#!/usr/bin/env bash
# CHP Audit Trail - Show violation history and tightening information

set -e

# Source core functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"

# Check if law name was provided
if [ -z "$1" ]; then
    log_error "Usage: $0 <law-name>"
    echo ""
    echo "Example:"
    echo "  $0 no-console-log"
    exit 1
fi

LAW_NAME="$1"

# Check if law exists
if ! law_exists "$LAW_NAME"; then
    log_error "Law '$LAW_NAME' not found"
    echo ""
    echo "Available laws:"
    for law_dir in "$LAWS_DIR"/*; do
        if [ -d "$law_dir" ]; then
            echo "  - $(basename "$law_dir")"
        fi
    done
    exit 1
fi

# Get law metadata
LAW_JSON="$LAWS_DIR/$LAW_NAME/law.json"
GUIDANCE_MD="$LAWS_DIR/$LAW_NAME/guidance.md"

if [ ! -f "$LAW_JSON" ]; then
    log_error "Law metadata file not found: $LAW_JSON"
    exit 1
fi

if [ ! -f "$GUIDANCE_MD" ]; then
    log_error "Law guidance file not found: $GUIDANCE_MD"
    exit 1
fi

# Extract metadata using jq
NAME=$(jq -r '.name // "unknown"' "$LAW_JSON")
SEVERITY=$(jq -r '.severity // "unknown"' "$LAW_JSON")
CREATED=$(jq -r '.created // "unknown"' "$LAW_JSON")
FAILURES=$(jq -r '.failures // 0' "$LAW_JSON")
TIGHTENING_LEVEL=$(jq -r '.tightening_level // 0' "$LAW_JSON")

# Display audit trail header
echo "Audit Trail: $NAME"
echo "============================="
echo "Severity: $SEVERITY"
echo "Created: $CREATED"
echo "Total Violations: $FAILURES"
echo "Tightening Level: $TIGHTENING_LEVEL"
echo ""

# Parse and display violation history from guidance.md
echo "Violation History:"

# Extract violation entries (sections between --- markers)
# Skip the first section (it's the main documentation)
# Look for entries starting with "**Violation:**"
VIOLATION_COUNT=0
IN_VIOLATION_SECTION=false
CURRENT_VIOLATION=""

while IFS= read -r line || [ -n "$line" ]; do
    if [[ "$line" == "---" ]]; then
        # End of a section
        if [ -n "$CURRENT_VIOLATION" ]; then
            # Check if this section contains a violation entry
            if echo "$CURRENT_VIOLATION" | grep -q "^\*\*Violation:\*\*"; then
                VIOLATION_COUNT=$((VIOLATION_COUNT + 1))
                # Extract the timestamp from the violation line
                TIMESTAMP=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Violation:\*\*" | sed 's/\*\*Violation:\*\* *//')
                echo "  #$VIOLATION_COUNT - $TIMESTAMP"

                # Optionally show more details
                if [ "${CHP_DEBUG:-false}" = "true" ]; then
                    CONTEXT=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Context:\*\*" | sed 's/\*\*Context:\*\* *//')
                    PATTERN=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Pattern:\*\*" | sed 's/\*\*Pattern:\*\* *//')
                    REMEDIATION=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Remediation:\*\*" | sed 's/\*\*Remediation:\*\* *//')

                    [ -n "$CONTEXT" ] && echo "      Context: $CONTEXT"
                    [ -n "$PATTERN" ] && echo "      Pattern: $PATTERN"
                    [ -n "$REMEDIATION" ] && echo "      Remediation: $REMEDIATION"
                fi
            fi
            CURRENT_VIOLATION=""
        fi
        IN_VIOLATION_SECTION=true
    else
        if [ "$IN_VIOLATION_SECTION" = "true" ]; then
            CURRENT_VIOLATION="$CURRENT_VIOLATION$line"$'\n'
        fi
    fi
done < "$GUIDANCE_MD"

# Process the last section if it exists and wasn't terminated by ---
if [ -n "$CURRENT_VIOLATION" ]; then
    # Check if this section contains a violation entry
    if echo "$CURRENT_VIOLATION" | grep -q "^\*\*Violation:\*\*"; then
        VIOLATION_COUNT=$((VIOLATION_COUNT + 1))
        # Extract the timestamp from the violation line
        TIMESTAMP=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Violation:\*\*" | sed 's/\*\*Violation:\*\* *//')
        echo "  #$VIOLATION_COUNT - $TIMESTAMP"

        # Optionally show more details
        if [ "${CHP_DEBUG:-false}" = "true" ]; then
            CONTEXT=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Context:\*\*" | sed 's/\*\*Context:\*\* *//')
            PATTERN=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Pattern:\*\*" | sed 's/\*\*Pattern:\*\* *//')
            REMEDIATION=$(echo "$CURRENT_VIOLATION" | grep "^\*\*Remediation:\*\*" | sed 's/\*\*Remediation:\*\* *//')

            [ -n "$CONTEXT" ] && echo "      Context: $CONTEXT"
            [ -n "$PATTERN" ] && echo "      Pattern: $PATTERN"
            [ -n "$REMEDIATION" ] && echo "      Remediation: $REMEDIATION"
        fi
    fi
fi

if [ "$VIOLATION_COUNT" -eq 0 ]; then
    echo "  No violations recorded"
fi

echo ""
