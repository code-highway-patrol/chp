#!/usr/bin/env bash
# CHP Marketplace Command
# Install and search for skills in the CHP marketplace

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_EXE="${NODE_EXE:-node}"

# Path to the CLI script
CLI_SCRIPT="$SCRIPT_DIR/../lib/cli.js"

if [ ! -f "$CLI_SCRIPT" ]; then
    echo "Error: CLI script not found at $CLI_SCRIPT" >&2
    exit 1
fi

# Execute with node, passing marketplace as the first argument
exec "$NODE_EXE" "$CLI_SCRIPT" marketplace "$@"
