#!/usr/bin/env bash
# CHP Repository Scanner
# Scan entire repository for potential violations (dry-run mode)

# Source core functions
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../core/common.sh"
source "$SCRIPT_DIR/../core/verifier.sh"

# Default values
SPECIFIC_LAW=""
SCAN_ALL_FILES=true
RUN_COVERAGE=false

# Display usage information
show_usage() {
    cat <<EOF
CHP Repository Scanner

Scan entire repository for potential violations in dry-run mode.

Usage:
    chp-scan [options]

Options:
    --law=<law-name>    Scan only for violations of a specific law
    --coverage          Analyze which files have no law coverage
    --help              Show this help message

Examples:
    chp-scan                          # Scan all laws against all files
    chp-scan --law=no-console-log    # Scan only for console.log violations

Output:
    - Violation count per law
    - List of files with violations
    - Severity levels
    - Total violation count

Note: This is a read-only scan. No files are modified.

EOF
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --law=*)
                SPECIFIC_LAW="${1#*=}"
                SCAN_ALL_FILES=false
                ;;
            --coverage)
                RUN_COVERAGE=true
                ;;
            --help|-h)
                show_usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
        shift
    done
}

# Scan all files in repository for a specific law
scan_law_files() {
    local law_name="$1"
    local law_dir="$LAWS_DIR/$law_name"
    local verify_script="$law_dir/verify.sh"

    if [[ ! -f "$verify_script" ]]; then
        log_error "Verification script not found: $verify_script"
        return 1
    fi

    log_info "Scanning for violations of: $law_name"

    # Skip non-code-quality laws (metrics, tracking, etc.)
    case "$law_name" in
        commit-metrics|test-*)
            echo ""
            echo "  Law: $law_name"
            echo "  Status: SKIPPED (not a scannable code quality law)"
            return 0
            ;;
    esac

    # Get all tracked files (not just staged), excluding common directories
    local all_files=$(git ls-files | grep -vE '^(node_modules/|\.git/|\.chp/|dist/|build/|\.next/|coverage/)' || true)

    # File extensions to skip
    local skip_pattern='\.(md|MD|json|txt|sh|yml|yaml|lock|gitignore)$'

    # Test files and directories to skip
    local test_pattern='^(tests?/|test/|__tests__/|.*test[-_].*\.(js|ts|tsx|py)$|test[-_].*\.js$)'

    local violations=0
    local violating_files=()

    # Define patterns and context for each law type
    local check_pattern=""
    local file_filter=""
    local skip_context=""

    case "$law_name" in
        no-console-log)
            check_pattern='console\.log'
            # Skip CLI tools and user-facing scripts
            skip_context='^(bin/|commands/|scripts/|lib/cli\.js)'
            ;;
        no-todos)
            check_pattern='TODO|FIXME|HACK|XXX'
            # Skip test files and documentation
            skip_context='^(tests?/|test/|docs/|\.github/)'
            ;;
        no-alerts)
            check_pattern='alert\('
            file_filter='\.(js|ts|tsx)$'
            # Skip test files
            skip_context='^(tests?/|test/|__tests__/|.*test[-_])'
            ;;
        no-api-keys)
            check_pattern='api[_-]?key|apikey|api[_-]?secret'
            # Skip test files and pattern definitions
            skip_context='^(tests?/|test/|commands/chp-scan)'
            ;;
        *)
            # Unknown law - skip
            echo ""
            echo "  Law: $law_name"
            echo "  Status: SKIPPED (no scan pattern defined)"
            return 0
            ;;
    esac

    # Scan all files
    while IFS= read -r file; do
        # Skip files that match the skip pattern
        if echo "$file" | grep -qE "$skip_pattern"; then
            continue
        fi

        # Skip test files
        if echo "$file" | grep -qE "$test_pattern"; then
            continue
        fi

        # Skip files in specific contexts (CLI tools, etc.)
        if [[ -n "$skip_context" ]] && echo "$file" | grep -qE "$skip_context"; then
            continue
        fi

        # Apply file filter if specified
        if [[ -n "$file_filter" ]] && ! echo "$file" | grep -qE "$file_filter"; then
            continue
        fi

        # Check if file exists
        if [ ! -f "$file" ]; then
            continue
        fi

        # For api-key, be smarter about context
        if [[ "$law_name" == "no-api-keys" ]]; then
            # Skip if it's in a string/pattern context (assignment, function arg)
            if grep -qE "$check_pattern" "$file" 2>/dev/null; then
                # Check if it's in a context that suggests a pattern/regex, not a real key
                # Skip lines with: pattern=, regex=, check_pattern=, PATTERNS=(, etc.
                if grep -E "$check_pattern" "$file" | grep -qvE "(pattern|regex|check_pattern|PATTERNS)="; then
                    violations=$((violations + 1))
                    violating_files+=("$file")
                fi
            fi
        else
            # For other laws, just check for pattern existence
            if grep -qE "$check_pattern" "$file" 2>/dev/null; then
                violations=$((violations + 1))
                violating_files+=("$file")
            fi
        fi
    done <<< "$all_files"

    # Get law metadata
    local severity=$(get_law_meta "$law_name" "severity")
    local failures=$(get_law_meta "$law_name" "failures")

    # Report results
    echo ""
    echo "  Law: $law_name"
    echo "  Severity: $severity"
    echo "  Historical failures: $failures"
    echo "  Current violations: $violations"

    if [ $violations -gt 0 ]; then
        echo "  Violating files:"
        for file in "${violating_files[@]}"; do
            echo "    - $file"
        done
    fi

    return 0
}

# Coverage gap analysis
run_coverage_analysis() {
    echo ""
    echo "=================================="
    echo "  CHP Coverage Analysis"
    echo "=================================="
    echo ""

    # Collect include/exclude patterns from all enabled laws
    local -A covered_extensions
    local -A law_names

    for law_dir in "$LAWS_DIR"/*; do
        [[ ! -d "$law_dir" ]] && continue
        local law_name
        law_name=$(basename "$law_dir")
        local law_json="$law_dir/law.json"

        [[ ! -f "$law_json" ]] && continue

        local enabled
        enabled=$(jq -r '.enabled // true' "$law_json" 2>/dev/null)
        [[ "$enabled" == "false" ]] && continue

        law_names["$law_name"]=1

        # Get include patterns
        local includes
        includes=$(jq -r '.include[]?' "$law_json" 2>/dev/null | tr -d '\r')

        if [[ -n "$includes" ]]; then
            while IFS= read -r pattern; do
                [[ -z "$pattern" ]] && continue
                # Extract extension from glob pattern
                local ext
                ext=$(echo "$pattern" | grep -oE '\*\.[a-zA-Z0-9]+$' | sed 's/\*\.//' | tr -d '\r')
                if [[ -n "$ext" ]]; then
                    covered_extensions["$ext"]="${covered_extensions[$ext]:-}:$law_name"
                fi
            done <<< "$includes"
        else
            # No include = all files covered
            covered_extensions["*"]="all:$law_name"
        fi
    done

    # Get all tracked files
    local all_files
    all_files=$(git ls-files | grep -vE '^(node_modules/|\.git/|\.chp/|dist/|build/|\.next/|coverage/)' || true)

    local total_files=0
    local covered_files=0
    local uncovered_files=0
    local -A uncovered_exts

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        total_files=$((total_files + 1))

        local ext="${file##*.}"
        local base="${file##*/}"
        local is_covered=false

        # Check if covered by wildcard (no include filter)
        if [[ -n "${covered_extensions["*"]}" ]]; then
            is_covered=true
        fi

        # Check extension-specific coverage
        if [[ "$is_covered" == "false" && -n "${covered_extensions[$ext]}" ]]; then
            is_covered=true
        fi

        if [[ "$is_covered" == "true" ]]; then
            covered_files=$((covered_files + 1))
        else
            uncovered_files=$((uncovered_files + 1))
            uncovered_exts["$ext"]=$((${uncovered_exts[$ext]:-0} + 1))
        fi
    done <<< "$all_files"

    echo "  Files analyzed: $total_files"
    echo "  Covered: $covered_files"
    echo "  Uncovered: $uncovered_files"
    echo ""

    if [[ ${#uncovered_exts[@]} -gt 0 ]]; then
        echo "  Uncovered file types:"
        for ext in "${!uncovered_exts[@]}"; do
            local count=${uncovered_exts[$ext]}
            echo "    .$ext — $count file(s)"
        done
    else
        echo "  All files are covered by at least one law."
    fi

    echo ""
    echo "  Active laws: ${#law_names[@]}"
    for law_name in "${!law_names[@]}"; do
        echo "    - $law_name"
    done

    echo ""
    return 0
}

# Main scan function
run_scan() {
    echo ""
    echo "=================================="
    echo "  CHP Repository Scanner"
    echo "  Mode: DRY-RUN (read-only)"
    echo "=================================="
    echo ""

    local total_violations=0
    local laws_scanned=0

    if [[ -n "$SPECIFIC_LAW" ]]; then
        # Scan specific law
        if ! law_exists "$SPECIFIC_LAW"; then
            log_error "Law does not exist: $SPECIFIC_LAW"
            return 1
        fi

        scan_law_files "$SPECIFIC_LAW"
        laws_scanned=1
    else
        # Scan all enabled laws
        for law_dir in "$LAWS_DIR"/*; do
            if [[ -d "$law_dir" ]]; then
                local law_name=$(basename "$law_dir")
                local law_json="$law_dir/law.json"

                if [[ -f "$law_json" ]]; then
                    # Check if law is enabled
                    local enabled
                    enabled=$(jq -r 'if has("enabled") then .enabled else "true" end' "$law_json" 2>/dev/null)

                    if [[ "$enabled" != "true" ]]; then
                        # Skip disabled laws
                        continue
                    fi

                    scan_law_files "$law_name"
                    laws_scanned=$((laws_scanned + 1))
                fi
            fi
        done
    fi

    echo ""
    echo "=================================="
    echo "  Scan Summary"
    echo "=================================="
    echo "  Laws scanned: $laws_scanned"
    echo "  Total violations: $total_violations"
    echo ""
    echo "  To fix violations:"
    echo "    1. Review violating files above"
    echo "    2. Fix the issues"
    echo "    3. Run chp-scan again to verify"
    echo "    4. Commit your changes"
    echo ""

    return 0
}

# Main entry point
main() {
    parse_args "$@"
    if [[ "$RUN_COVERAGE" == "true" ]]; then
        run_coverage_analysis
    else
        run_scan
    fi
}

# Run main
main "$@"
