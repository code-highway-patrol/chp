{
  "hooks": {
    "pre-commit": {
      "laws": [
        "no-alerts",
        "no-api-keys",
        "no-console-log",
        "no-todos",
        "test-scope",
        "test-update-scope"
      ],
      "enabled": true,
      "blocking": true
    },
    "post-commit": {
      "laws": [
        "commit-metrics"
      ],
      "enabled": true,
      "blocking": true
    },
    "pre-tool": {
      "laws": [
        "mandarin-only",
        "no-alerts",
        "no-api-keys",
        "no-console-log",
        "no-todos"
      ],
      "enabled": true,
      "blocking": true
    },
    "pre-push": {
      "laws": [
        "no-alerts",
        "no-api-keys",
        "no-todos"
      ],
      "enabled": true,
      "blocking": true
    },
    "post-tool": {
      "laws": [
        "no-api-keys"
      ],
      "enabled": true,
      "blocking": true
    }
  },
  "version": "1.0"
}
