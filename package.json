{
  "name": "chp",
  "displayName": "Code Health Protocol",
  "version": "1.0.0",
  "description": "Highway Patrol for your code - enforcing traffic laws, catching speeders, and keeping your codebase safe",
  "type": "module",
  "main": "index.js",
  "bin": {
    "chp": "./bin/chp",
    "chp-analyze": "./scripts/analyze.js",
    "chp-check": "./scripts/check.js",
    "chp-validate": "./scripts/validate.js",
    "chp-serve": "./lib/mcp-server.cjs"
  },
  "scripts": {
    "analyze": "node scripts/analyze.js",
    "check": "node scripts/check.js",
    "validate": "node scripts/validate.js",
    "serve": "node lib/mcp-server.js",
    "ui": "node server/index.cjs",
    "test": "node scripts/test.js",
    "lint": "node scripts/lint.js"
  },
  "keywords": [
    "static-analysis",
    "code-quality",
    "linting",
    "rules",
    "standards",
    "best-practices",
    "security",
    "code-review",
    "claude-code",
    "mcp"
  ],
  "author": "justi",
  "license": "MIT",
  "homepage": "https://github.com/code-highway-patrol/chp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-highway-patrol/chp.git"
  },
  "bugs": {
    "url": "https://github.com/code-highway-patrol/chp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0",
    "jsonschema": "^1.4.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "skills/",
    "hooks/",
    "commands/",
    "assets/",
    "agents/",
    "server/",
    "ui/dist/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/",
    ".windsurf-plugin/",
    "gemini-extension.json"
  ]
}