#!/bin/bash
# Emit active CHP laws as additionalContext so the agent sees them before writing code.

find_laws_file() {
    local project_dir="${CLAUDE_PROJECT_DIR:-$(pwd)}"
    local laws_path="$project_dir/laws/chp-laws.txt"
    if [[ -f "$laws_path" ]]; then
        echo "$laws_path"
        return
    fi
    local plugin_root="${CLAUDE_PLUGIN_ROOT:-}"
    if [[ -n "$plugin_root" ]]; then
        local fallback="$plugin_root/laws/chp-laws.txt"
        if [[ -f "$fallback" ]]; then
            echo "$fallback"
            return
        fi
    fi
    echo ""
}

main() {
    local laws_path
    laws_path=$(find_laws_file)
    if [[ -z "$laws_path" ]]; then
        exit 0
    fi

    local law_name=""
    local intent=""
    local reaction=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line//$'\r'/}"
        case "$line" in
            "# === Law:"*)
                if [[ -n "$law_name" && -n "$intent" ]]; then
                    echo "  [${reaction^^}] $law_name: $intent"
                fi
                law_name=$(echo "$line" | sed 's/^# === Law: //;s/ ===$//')
                intent=""
                reaction=""
                ;;
            intent:" "*)
                intent="${line#intent: }"
                ;;
            reaction:" "*)
                reaction="${line#reaction: }"
                ;;
        esac
    done < "$laws_path"

    if [[ -n "$law_name" && -n "$intent" ]]; then
        echo "  [${reaction^^}] $law_name: $intent"
    fi
}

output=$(main "$@")
echo "{\"additionalContext\": \"CHP ACTIVE LAWS — you MUST follow these when writing code:$output\"}"
