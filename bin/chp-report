#!/bin/bash
# Generate a text report from .chp/report.json.

main() {
    local project_dir="${CLAUDE_PROJECT_DIR:-$(pwd)}"
    local report_path="$project_dir/.chp/report.json"

    if [[ ! -f "$report_path" ]]; then
        echo "No report found. Run /chp:scan-repo first." >&2
        exit 1
    fi

    local timestamp files_checked total_violations total_block total_warn
    timestamp=$(awk -F'"' '/"timestamp"/{print $4; exit}' "$report_path")
    files_checked=$(awk -F'[: ,]+' '/"files_checked"/{print $3; exit}' "$report_path")
    total_violations=$(awk -F'[: ,]+' '/"total_violations"/{print $3; exit}' "$report_path")
    total_block=$(awk -F'[: ,]+' '/"total_block"/{print $3; exit}' "$report_path")
    total_warn=$(awk -F'[: ,]+' '/"total_warn"/{print $3; exit}' "$report_path")

    echo "=================================="
    echo "  CHP Violation Report"
    echo "=================================="
    echo ""
    echo "Generated: ${timestamp:-unknown}"
    echo "Files scanned: ${files_checked:-0}"
    echo ""
    echo "Summary:"
    echo "  Total violations: ${total_violations:-0}"
    echo "  Blocked: ${total_block:-0}"
    echo "  Warnings: ${total_warn:-0}"
    echo ""

    if [[ "$total_violations" == "0" || -z "$total_violations" ]]; then
        echo "No violations found. All clear."
    else
        echo "Violations:"
        grep -oP '"law": "\K[^"]+| "file": "\K[^"]+| "line": \K[0-9]+| "snippet": "\K[^"]+' "$report_path" | paste - - - - | while read -r law file line snippet; do
            local filename="${file##*/}"
            echo "  [$law] $filename:${line}: ${snippet:0:80}"
        done
    fi

    echo ""
    echo "Full report: .chp/report.json"
}

main "$@"
