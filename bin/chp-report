#!/usr/bin/env python3
"""Generate an HTML report from .chp/report.json."""

import json
import os
import sys
from datetime import datetime
from pathlib import Path

HTML_TEMPLATE = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CHP Report</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0a0a0a; color: #e0e0e0; min-height: 100vh; }
  .container { max-width: 960px; margin: 0 auto; padding: 40px 24px; }
  header { margin-bottom: 48px; }
  header h1 { font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }
  header h1 span { color: #3b82f6; }
  header p { color: #888; margin-top: 6px; font-size: 14px; }
  .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 40px; }
  .card { background: #141414; border: 1px solid #222; border-radius: 12px; padding: 20px; }
  .card .label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #666; margin-bottom: 8px; }
  .card .value { font-size: 32px; font-weight: 700; }
  .card .value.red { color: #ef4444; }
  .card .value.yellow { color: #eab308; }
  .card .value.green { color: #22c55e; }
  .card .value.blue { color: #3b82f6; }
  .law-group { margin-bottom: 32px; }
  .law-header { display: flex; align-items: center; gap: 12px; padding: 16px 20px; background: #141414; border: 1px solid #222; border-radius: 12px 12px 0 0; cursor: pointer; user-select: none; }
  .law-header:hover { background: #1a1a1a; }
  .law-header .badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.3px; }
  .badge.block { background: #ef44441a; color: #ef4444; border: 1px solid #ef444433; }
  .badge.warn { background: #eab3081a; color: #eab308; border: 1px solid #eab30833; }
  .law-header .name { font-weight: 600; color: #fff; font-size: 15px; }
  .law-header .count { margin-left: auto; color: #666; font-size: 13px; }
  .law-header .arrow { color: #444; transition: transform 0.2s; }
  .law-header.open .arrow { transform: rotate(90deg); }
  .law-body { border: 1px solid #222; border-top: none; border-radius: 0 0 12px 12px; overflow: hidden; }
  .law-intent { padding: 14px 20px; background: #111; color: #888; font-size: 13px; border-bottom: 1px solid #1a1a1a; }
  .violation { padding: 12px 20px; border-bottom: 1px solid #1a1a1a; font-size: 13px; display: flex; gap: 16px; align-items: baseline; }
  .violation:last-child { border-bottom: none; }
  .violation:hover { background: #111; }
  .violation .loc { color: #3b82f6; white-space: nowrap; min-width: 180px; font-family: 'SF Mono', 'Fira Code', monospace; font-size: 12px; }
  .violation .snippet { color: #999; font-family: 'SF Mono', 'Fira Code', monospace; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .violation .tag { font-size: 10px; padding: 2px 6px; border-radius: 4px; font-weight: 600; white-space: nowrap; }
  .tag.det { background: #3b82f61a; color: #3b82f6; }
  .tag.sub { background: #a855f71a; color: #a855f7; }
  .empty { text-align: center; padding: 80px 20px; color: #444; }
  .empty .icon { font-size: 48px; margin-bottom: 16px; }
  .empty p { font-size: 16px; }
  @media (max-width: 640px) { .cards { grid-template-columns: repeat(2, 1fr); } }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1><span>CHP</span> Violation Report</h1>
    <p>Generated {timestamp} &middot; {files_checked} files scanned</p>
  </header>
  <div class="cards">
    <div class="card"><div class="label">Total</div><div class="value blue">{total}</div></div>
    <div class="card"><div class="label">Blocked</div><div class="value red">{block}</div></div>
    <div class="card"><div class="label">Warnings</div><div class="value yellow">{warn}</div></div>
    <div class="card"><div class="label">Laws Violated</div><div class="value {pass_color}">{laws_violated}</div></div>
  </div>
  {content}
</div>
<script>
document.querySelectorAll('.law-header').forEach(h => {
  h.addEventListener('click', () => {
    h.classList.toggle('open');
    h.nextElementSibling.style.display = h.classList.contains('open') ? 'block' : 'none';
  });
});
</script>
</body>
</html>"""


def relative_path(filepath, project_dir):
    try:
        return str(Path(filepath).relative_to(project_dir))
    except ValueError:
        return filepath


def generate_html(report, project_dir):
    ts = report.get("timestamp", "")
    try:
        dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
        ts_display = dt.strftime("%b %d, %Y at %H:%M UTC")
    except (ValueError, AttributeError):
        ts_display = ts

    total = report.get("total_violations", 0)
    block = report.get("total_block", 0)
    warn = report.get("total_warn", 0)
    files_checked = report.get("files_checked", 0)
    summary = report.get("summary", {})
    violations = report.get("violations", [])

    if not violations:
        content = '<div class="empty"><div class="icon">&#10003;</div><p>No violations found. All clear.</p></div>'
    else:
        groups = {}
        for v in violations:
            lid = v["law"]
            if lid not in groups:
                groups[lid] = []
            groups[lid].append(v)

        content = ""
        for lid, vlist in sorted(groups.items(), key=lambda x: (-len(x[1]), x[0])):
            info = summary.get(lid, {})
            reaction = info.get("reaction", vlist[0].get("reaction", "warn"))
            intent = info.get("intent", vlist[0].get("intent", ""))

            rows = ""
            for v in vlist:
                rel = relative_path(v.get("file", ""), project_dir)
                line = v.get("line", "")
                snippet = v.get("snippet", v.get("detail", ""))
                vtype = v.get("type", "deterministic")
                tag_class = "det" if vtype == "deterministic" else "sub"
                tag_label = "AUTO" if vtype == "deterministic" else "REVIEW"
                rows += f'<div class="violation"><span class="tag {tag_class}">{tag_label}</span><span class="loc">{rel}:{line}</span><span class="snippet">{snippet}</span></div>\n'

            content += f"""<div class="law-group">
  <div class="law-header open"><span class="badge {reaction}">{reaction}</span><span class="name">{lid}</span><span class="count">{len(vlist)} violation{"s" if len(vlist) != 1 else ""}</span><span class="arrow">&#9654;</span></div>
  <div class="law-body"><div class="law-intent">{intent}</div>{rows}</div>
</div>\n"""

    replacements = {
        "{timestamp}": ts_display,
        "{files_checked}": str(files_checked),
        "{total}": str(total),
        "{block}": str(block),
        "{warn}": str(warn),
        "{laws_violated}": str(len(summary)),
        "{pass_color}": "green" if len(summary) == 0 else "red",
        "{content}": content,
    }
    result = HTML_TEMPLATE
    for key, val in replacements.items():
        result = result.replace(key, val)
    return result


def main():
    project_dir = os.environ.get("CLAUDE_PROJECT_DIR", os.getcwd())
    report_path = Path(project_dir) / ".chp" / "report.json"

    if not report_path.exists():
        print("No report found. Run /chp:scan-repo first.", file=sys.stderr)
        sys.exit(1)

    report = json.loads(report_path.read_text(encoding="utf-8"))
    html = generate_html(report, project_dir)

    out_path = Path(project_dir) / ".chp" / "report.html"
    out_path.write_text(html, encoding="utf-8")
    print(f"Report written to {out_path}")


if __name__ == "__main__":
    main()
