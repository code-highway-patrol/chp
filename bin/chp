#!/bin/bash
# CHP - Code Highway Patrol
# Bash wrapper for CHP commands

set -e

# Get the directory containing this script
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMANDS_DIR="$BIN_DIR/../commands"

# Check if commands directory exists
if [[ ! -d "$COMMANDS_DIR" ]]; then
    echo "Error: CHP commands not found at $COMMANDS_DIR" >&2
    exit 1
fi

# If no arguments, show help
if [[ $# -eq 0 ]]; then
    echo "CHP - Code Highway Patrol"
    echo ""
    echo "Available commands:"
    echo "  chp-law          Manage laws (create, list, delete, test)"
    echo "  chp-hooks        Manage hooks (list, enable, disable)"
    echo "  chp-status       Show CHP status"
    echo "  chp-audit        Audit codebase for violations"
    echo "  chp-scan         Scan for issues"
    echo "  chp-install      Install law from marketplace"
    echo "  chp-search       Search marketplace"
    echo "  chp-show         Show law details"
    echo "  chp-list         List marketplace laws"
    echo "  chp-publish      Publish law to marketplace"
    echo ""
    echo "Run 'chp-<command> help' for more info"
    exit 0
fi

# Get the command
cmd="$1"
shift

# Map common shortcuts to actual commands
case "$cmd" in
    law|laws)
        exec "$COMMANDS_DIR/chp-law" "$@"
        ;;
    hooks)
        exec "$COMMANDS_DIR/chp-hooks" "$@"
        ;;
    status)
        exec "$COMMANDS_DIR/chp-status" "$@"
        ;;
    audit)
        exec "$COMMANDS_DIR/chp-audit" "$@"
        ;;
    scan)
        exec "$COMMANDS_DIR/chp-scan" "$@"
        ;;
    install)
        exec "$COMMANDS_DIR/chp-install" "$@"
        ;;
    search)
        exec "$COMMANDS_DIR/chp-search" "$@"
        ;;
    show)
        exec "$COMMANDS_DIR/chp-show" "$@"
        ;;
    list)
        exec "$COMMANDS_DIR/chp-list" "$@"
        ;;
    publish)
        exec "$COMMANDS_DIR/chp-publish" "$@"
        ;;
    login)
        exec "$COMMANDS_DIR/chp-login" "$@"
        ;;
    marketplace)
        exec "$COMMANDS_DIR/chp-marketplace" "$@"
        ;;
    *)
        echo "Error: unknown command: $cmd" >&2
        echo "Run 'chp' to see available commands" >&2
        exit 1
        ;;
esac
