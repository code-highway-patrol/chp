#!/usr/bin/env python3
"""CHP deterministic law checker. Scans files against laws that have a check: regex pattern."""

import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

SKIP_DIRS = {".git", "node_modules", "dist", "build", ".next", "__pycache__", ".venv", "venv", ".chp"}
SKIP_EXT = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".ico", ".svg", ".woff", ".woff2",
            ".ttf", ".eot", ".zip", ".tar", ".gz", ".lock", ".map", ".min.js", ".min.css",
            ".pyc", ".exe", ".dll", ".so", ".dylib"}
SKIP_FILES = {"chp-laws.txt", "package-lock.json", "yarn.lock"}


def find_laws_file():
    project_dir = os.environ.get("CLAUDE_PROJECT_DIR", os.getcwd())
    laws_path = Path(project_dir) / "laws" / "chp-laws.txt"
    if laws_path.exists():
        return laws_path
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")
    if plugin_root:
        fallback = Path(plugin_root) / "laws" / "chp-laws.txt"
        if fallback.exists():
            return fallback
    return None


def parse_laws(text):
    laws = []
    current = None
    for line in text.splitlines():
        header = re.match(r"^#\s*===\s*Law:\s*(\S+)\s*===", line)
        if header:
            current = {"id": header.group(1)}
            laws.append(current)
            continue
        if current is None or line.startswith("#"):
            continue
        if line.startswith("intent:"):
            current["intent"] = line.split(":", 1)[1].strip()
        elif line.startswith("check:"):
            current["check"] = line.split(":", 1)[1].strip()
        elif line.startswith("reaction:"):
            current["reaction"] = line.split(":", 1)[1].strip()
    return laws


def collect_files(root, single_file=None):
    if single_file:
        p = Path(single_file)
        if p.exists() and p.is_file():
            return [p]
        return []
    files = []
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        for f in filenames:
            p = Path(dirpath) / f
            if p.suffix.lower() in SKIP_EXT or p.name in SKIP_FILES:
                continue
            files.append(p)
    return files


def check_file(filepath, deterministic_laws):
    violations = []
    try:
        content = filepath.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return violations
    for i, line in enumerate(content.splitlines(), 1):
        for law in deterministic_laws:
            try:
                if re.search(law["check"], line):
                    violations.append({
                        "law": law["id"],
                        "reaction": law.get("reaction", "warn"),
                        "intent": law.get("intent", ""),
                        "type": "deterministic",
                        "file": str(filepath),
                        "line": i,
                        "snippet": line.strip()[:120]
                    })
            except re.error:
                continue
    return violations


def build_report(all_violations, files_checked):
    summary = {}
    for v in all_violations:
        lid = v["law"]
        if lid not in summary:
            summary[lid] = {"count": 0, "reaction": v["reaction"], "intent": v["intent"], "type": v["type"]}
        summary[lid]["count"] += 1

    return {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "files_checked": files_checked,
        "total_violations": len(all_violations),
        "total_block": sum(1 for v in all_violations if v["reaction"] == "block"),
        "total_warn": sum(1 for v in all_violations if v["reaction"] == "warn"),
        "violations": all_violations,
        "summary": summary
    }


def main():
    single_file = None
    is_hook = os.environ.get("CLAUDE_PLUGIN_ROOT") and len(sys.argv) == 1

    if is_hook:
        try:
            raw = sys.stdin.read()
            event = json.loads(raw)
            tool_input = event.get("tool_input", {})
            if isinstance(tool_input, str):
                tool_input = json.loads(tool_input)
            single_file = tool_input.get("path") or tool_input.get("file_path")
        except (json.JSONDecodeError, AttributeError, EOFError):
            pass

    for arg in sys.argv[1:]:
        if arg.startswith("--file="):
            single_file = arg.split("=", 1)[1]

    laws_path = find_laws_file()
    if not laws_path:
        return

    laws = parse_laws(laws_path.read_text(encoding="utf-8"))
    deterministic = [l for l in laws if "check" in l]
    if not deterministic:
        return

    project_dir = os.environ.get("CLAUDE_PROJECT_DIR", os.getcwd())
    files = collect_files(project_dir, single_file)
    all_violations = []
    for f in files:
        all_violations.extend(check_file(f, deterministic))

    report = build_report(all_violations, len(files))

    report_dir = Path(project_dir) / ".chp"
    report_dir.mkdir(exist_ok=True)
    report_path = report_dir / "report.json"
    report_path.write_text(json.dumps(report, indent=2), encoding="utf-8")

    if all_violations:
        lines = [f"CHP: {len(all_violations)} violation(s) found by deterministic checks:"]
        for v in all_violations:
            lines.append(f"  [{v['reaction'].upper()}] {v['law']} — {Path(v['file']).name}:{v['line']}: {v['snippet']}")
        lines.append(f"\nFull report: .chp/report.json")
        print(json.dumps({"additionalContext": "\n".join(lines)}))


if __name__ == "__main__":
    main()
