#!/bin/bash
# CHP deterministic law checker. Scans files against laws that have a check: regex pattern.

SKIP_DIRS="node_modules dist build .next __pycache__ .venv venv .chp .git"
SKIP_EXT="png jpg jpeg gif webp ico svg woff woff2 ttf eot zip tar gz lock map min.js min.css pyc exe dll so dylib"

find_laws_file() {
    local project_dir="${CLAUDE_PROJECT_DIR:-$(pwd)}"
    local laws_path="$project_dir/laws/chp-laws.txt"
    if [[ -f "$laws_path" ]]; then
        echo "$laws_path"
        return
    fi
    local plugin_root="${CLAUDE_PLUGIN_ROOT:-}"
    if [[ -n "$plugin_root" ]]; then
        local fallback="$plugin_root/laws/chp-laws.txt"
        if [[ -f "$fallback" ]]; then
            echo "$fallback"
            return
        fi
    fi
    echo ""
}

main() {
    local single_file=""
    local is_hook=false

    if [[ -n "$CLAUDE_PLUGIN_ROOT" && $# -eq 0 ]]; then
        is_hook=true
        local raw
        raw=$(cat)
        if [[ -n "$raw" ]]; then
            single_file=$(echo "$raw" | grep -o '"path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"')
            if [[ -z "$single_file" ]]; then
                single_file=$(echo "$raw" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | grep -o '"[^"]*"$' | tr -d '"')
            fi
        fi
    fi

    for arg in "$@"; do
        if [[ "$arg" =~ --file=(.+) ]]; then
            single_file="${BASH_REMATCH[1]}"
        fi
    done

    local laws_path
    laws_path=$(find_laws_file)
    if [[ -z "$laws_path" ]]; then
        exit 0
    fi

    local project_dir="${CLAUDE_PROJECT_DIR:-$(pwd)}"

    local files=()
    if [[ -n "$single_file" && -f "$single_file" ]]; then
        files=("$single_file")
    else
        while IFS= read -r file; do
            local ext="${file##*.}"
            local basename="$(basename "$file")"
            if [[ " $SKIP_EXT " != *" $ext "* ]] && [[ " $SKIP_FILES " != *" $basename "* ]]; then
                files+=("$file")
            fi
        done < <(find "$project_dir" -type f 2>/dev/null | grep -v -E "/($SKIP_DIRS)/" | grep -v '/node_modules/' | grep -v '/.git/')
    fi

    local laws_data=""
    local in_law=false
    local current_law=""
    local current_pattern=""
    local current_reaction="warn"
    local current_intent=""

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line//$'\r'/}"
        case "$line" in
            "# === Law:"*)
                if $in_law && [[ -n "$current_law" && -n "$current_pattern" ]]; then
                    laws_data="$laws_data${current_law}|${current_pattern}|${current_reaction}|${current_intent}"$'\n'
                fi
                current_law=$(echo "$line" | sed 's/^# === Law: //;s/ ===$//')
                current_pattern=""
                current_reaction="warn"
                current_intent=""
                in_law=true
                ;;
            "intent: "*)
                current_intent="${line#intent: }"
                ;;
            "reaction: "*)
                current_reaction="${line#reaction: }"
                ;;
            "check: "*)
                current_pattern="${line#check: }"
                ;;
        esac
    done < "$laws_path"

    if $in_law && [[ -n "$current_law" && -n "$current_pattern" ]]; then
        laws_data="$laws_data${current_law}|${current_pattern}|${current_reaction}|${current_intent}"$'\n'
    fi

    if [[ -z "$laws_data" ]]; then
        exit 0
    fi

    local all_violations=""
    for file in "${files[@]}"; do
        [[ ! -f "$file" ]] && continue
        local line_num=0
        while IFS= read -r line || [[ -n "$line" ]]; do
            line_num=$((line_num + 1))
            while IFS='|' read -r law_id pattern reaction intent; do
                if [[ -z "$pattern" ]]; then
                    continue
                fi
                if grep -qE "$pattern" <<< "$line" 2>/dev/null; then
                    local snippet="${line:0:120}"
                    all_violations="$all_violations${law_id}|${reaction}|${intent}|${file}|${line_num}|${snippet}"$'\n'
                fi
            done <<< "$laws_data"
        done < "$file"
    done

    local total=0
    local total_block=0
    local total_warn=0
    while IFS='|' read -r law reaction intent file line snippet; do
        [[ -z "$law" ]] && continue
        total=$((total + 1))
        [[ "$reaction" == "block" ]] && total_block=$((total_block + 1))
        [[ "$reaction" == "warn" ]] && total_warn=$((total_warn + 1))
    done <<< "$all_violations"

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    local report_dir="$project_dir/.chp"
    mkdir -p "$report_dir"
    local report_path="$report_dir/report.json"

    local violations_json="["
    local first=true
    while IFS='|' read -r law reaction intent file line snippet; do
        [[ -z "$law" ]] && continue
        if $first; then
            first=false
        else
            violations_json="${violations_json},"
        fi
        violations_json="${violations_json}{\"law\": \"$law\", \"reaction\": \"$reaction\", \"intent\": \"$intent\", \"file\": \"$file\", \"line\": $line, \"snippet\": \"$snippet\"}"
    done <<< "$all_violations"
    violations_json="${violations_json}]"

    cat > "$report_path" << EOF
{
  "timestamp": "$timestamp",
  "files_checked": ${#files[@]},
  "total_violations": $total,
  "total_block": $total_block,
  "total_warn": $total_warn,
  "violations": $violations_json,
  "summary": {}
}
EOF

    local violation_count=0
    violation_count=$(echo "$all_violations" | grep -c '|' || echo "0")

    if [[ "$violation_count" -gt 0 ]]; then
        local lines="CHP: $violation_count violation(s) found by deterministic checks:"
        while IFS='|' read -r law reaction intent file line snippet; do
            [[ -z "$law" ]] && continue
            local filename
            filename=$(basename "$file")
            lines="$lines"$'\n'"  [${reaction^^}] $law — ${filename}:${line}: ${snippet}"
        done <<< "$all_violations"
        lines="$lines"$'\n'"Full report: .chp/report.json"
        echo "{\"additionalContext\": \"$lines\"}"
    fi
}

main "$@"
