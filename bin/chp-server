<script>
const API = '';

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.remove('hidden');
  setTimeout(() => t.classList.add('hidden'), 2500);
}

document.querySelectorAll('nav a').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.querySelectorAll('nav a').forEach(x => x.classList.remove('active'));
    a.classList.add('active');
    const page = a.dataset.page;
    document.querySelectorAll('main > div').forEach(d => d.classList.add('hidden'));
    document.getElementById('page-' + page).classList.remove('hidden');
    if (page === 'laws') loadLaws();
    if (page === 'report') loadReport();
  });
});

async function loadLaws() {
  const res = await fetch(API + '/api/laws');
  const laws = await res.json();
  const det = laws.filter(l => l.check);
  const sub = laws.filter(l => !l.check);
  const blk = laws.filter(l => l.reaction === 'block');

  document.getElementById('law-stats').innerHTML = `
    <div class="stat"><div class="label">Total Laws</div><div class="val b">${laws.length}</div></div>
    <div class="stat"><div class="label">Deterministic</div><div class="val g">${det.length}</div></div>
    <div class="stat"><div class="label">Subjective</div><div class="val y">${sub.length}</div></div>
    <div class="stat"><div class="label">Blocking</div><div class="val r">${blk.length}</div></div>
  `;

  if (laws.length === 0) {
    document.getElementById('law-list').innerHTML = '<div class="empty-state"><div class="big">&#9888;</div><p>No laws defined. Create one to get started.</p></div>';
    return;
  }

  document.getElementById('law-list').innerHTML = laws.map(l => `
    <div class="law">
      <span class="badge ${l.reaction || 'warn'}">${l.reaction || 'warn'}</span>
      <span class="name">${l.id}</span>
      <span class="intent">${l.intent || ''}</span>
      <span class="type ${l.check ? 'auto' : 'review'}">${l.check ? 'AUTO' : 'REVIEW'}</span>
      <span class="actions"><button class="del" onclick="deleteLaw('${l.id}')">Delete</button></span>
    </div>
  `).join('');
}

async function createLaw() {
  const id = document.getElementById('new-id').value.trim();
  const intent = document.getElementById('new-intent').value.trim();
  const check = document.getElementById('new-check').value.trim();
  const reaction = document.getElementById('new-reaction').value;
  if (!id || !intent) { alert('ID and Intent are required'); return; }

  const body = { id, intent, reaction };
  if (check) body.check = check;

  const res = await fetch(API + '/api/laws', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
  if (res.ok) {
    showToast('Law created: ' + id);
    document.getElementById('new-id').value = '';
    document.getElementById('new-intent').value = '';
    document.getElementById('new-check').value = '';
  } else {
    const err = await res.json();
    alert(err.error || 'Failed to create law');
  }
}

async function deleteLaw(id) {
  if (!confirm('Delete law: ' + id + '?')) return;
  const res = await fetch(API + '/api/laws/' + id, { method: 'DELETE' });
  if (res.ok) { showToast('Deleted: ' + id); loadLaws(); }
}

async function runScan() {
  document.getElementById('scan-btn').disabled = true;
  document.getElementById('scan-status').classList.remove('hidden');
  document.getElementById('scan-result').innerHTML = '';
  try {
    const res = await fetch(API + '/api/scan', { method: 'POST' });
    const data = await res.json();
    document.getElementById('scan-result').innerHTML = `
      <div class="card">
        <p style="color:#22c55e;font-weight:600;margin-bottom:8px">Scan complete</p>
        <p style="color:#a1a1aa;font-size:14px">${data.files_checked} files checked &middot; ${data.total_violations} violations found</p>
      </div>`;
  } catch(e) {
    document.getElementById('scan-result').innerHTML = '<div class="card"><p style="color:#ef4444">Scan failed: ' + e.message + '</p></div>';
  }
  document.getElementById('scan-btn').disabled = false;
  document.getElementById('scan-status').classList.add('hidden');
}

async function loadReport() {
  let data;
  try {
    const res = await fetch(API + '/api/report');
    if (!res.ok) throw new Error();
    data = await res.json();
  } catch {
    document.getElementById('report-stats').innerHTML = '';
    document.getElementById('report-content').innerHTML = '<div class="empty-state"><div class="big">&#128269;</div><p>No report yet. Run a scan first.</p></div>';
    return;
  }

  const t = data.total_violations || 0;
  const b = data.total_block || 0;
  const w = data.total_warn || 0;
  const lv = Object.keys(data.summary || {}).length;
  document.getElementById('report-stats').innerHTML = `
    <div class="stat"><div class="label">Total</div><div class="val b">${t}</div></div>
    <div class="stat"><div class="label">Blocked</div><div class="val r">${b}</div></div>
    <div class="stat"><div class="label">Warnings</div><div class="val y">${w}</div></div>
    <div class="stat"><div class="label">Laws Violated</div><div class="val ${lv===0?'g':'r'}">${lv}</div></div>
  `;

  const violations = data.violations || [];
  if (violations.length === 0) {
    document.getElementById('report-content').innerHTML = '<div class="empty-state"><div class="big">&#10003;</div><p>No violations. All clear.</p></div>';
    return;
  }

  const groups = {};
  violations.forEach(v => { if (!groups[v.law]) groups[v.law] = []; groups[v.law].push(v); });

  let html = '';
  for (const [lid, vlist] of Object.entries(groups).sort((a,b) => b[1].length - a[1].length)) {
    const info = (data.summary||{})[lid] || vlist[0];
    const reaction = info.reaction || 'warn';
    const rows = vlist.map(v => {
      const file = (v.file||'').split(/[/\\]/).slice(-2).join('/');
      const vtypeClass = v.type === 'subjective' ? 'sub' : 'det';
      const vtypeLabel = v.type === 'subjective' ? 'REVIEW' : 'AUTO';
      return `<div class="violation"><span class="vtag ${vtypeClass}">${vtypeLabel}</span><span class="loc">${file}:${v.line||''}</span><span class="snip">${v.snippet||v.detail||''}</span></div>`;
    }).join('');
    html += `<div class="group-header open" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.classList.contains('open')?'block':'none'">
      <span class="gh-badge badge ${reaction}">${reaction}</span><span class="gh-name">${lid}</span><span class="gh-count">${vlist.length}</span><span class="gh-arrow">&#9654;</span>
    </div><div class="group-body">${rows}</div>`;
  }
  document.getElementById('report-content').innerHTML = html;
}

loadLaws();
</script>
</body>
</html>"""


class CHPHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

    def send_json(self, data, status=200):
        body = json.dumps(data).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", len(body))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, html):
        body = html.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self):
        path = urlparse(self.path).path

        if path == "/" or path == "":
            self.send_html(DASHBOARD_HTML)

        elif path == "/api/laws":
            if LAWS_FILE.exists():
                laws = parse_laws(LAWS_FILE.read_text(encoding="utf-8"))
            else:
                laws = []
            self.send_json(laws)

        elif path == "/api/report":
            if REPORT_FILE.exists():
                report = json.loads(REPORT_FILE.read_text(encoding="utf-8"))
                self.send_json(report)
            else:
                self.send_json({"error": "No report found"}, 404)

        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        path = urlparse(self.path).path

        if path == "/api/laws":
            length = int(self.headers.get("Content-Length", 0))
            body = json.loads(self.rfile.read(length))
            law_id = body.get("id", "").strip()
            intent = body.get("intent", "").strip()
            reaction = body.get("reaction", "warn")
            check = body.get("check", "").strip()

            if not law_id or not intent:
                self.send_json({"error": "id and intent are required"}, 400)
                return

            if LAWS_FILE.exists():
                existing = LAWS_FILE.read_text(encoding="utf-8")
                if f"Law: {law_id} ===" in existing:
                    self.send_json({"error": f"Law '{law_id}' already exists"}, 409)
                    return
            else:
                LAWS_FILE.parent.mkdir(parents=True, exist_ok=True)
                existing = ""

            new_law = {"id": law_id, "intent": intent, "reaction": reaction}
            if check:
                new_law["check"] = check

            separator = "\n" if existing and not existing.endswith("\n") else ""
            extra_newline = "\n" if existing.strip() else ""
            LAWS_FILE.write_text(existing + separator + extra_newline + serialize_law(new_law) + "\n", encoding="utf-8")
            self.send_json(new_law, 201)

        elif path == "/api/scan":
            check_script = Path(PLUGIN_ROOT) / "bin" / "chp-check"
            env = {**os.environ, "CLAUDE_PROJECT_DIR": PROJECT_DIR}
            try:
                subprocess.run([sys.executable, str(check_script)], env=env, timeout=30, capture_output=True)
            except Exception:
                pass
            if REPORT_FILE.exists():
                report = json.loads(REPORT_FILE.read_text(encoding="utf-8"))
                self.send_json(report)
            else:
                self.send_json({"files_checked": 0, "total_violations": 0})

        else:
            self.send_response(404)
            self.end_headers()

    def do_DELETE(self):
        path = urlparse(self.path).path
        if path.startswith("/api/laws/"):
            law_id = path.split("/api/laws/")[1]
            if not LAWS_FILE.exists():
                self.send_json({"error": "Laws file not found"}, 404)
                return

            text = LAWS_FILE.read_text(encoding="utf-8")
            blocks = re.split(r"(?=^# === Law:)", text, flags=re.MULTILINE)
            new_blocks = [b for b in blocks if f"Law: {law_id} ===" not in b]

            if len(new_blocks) == len(blocks):
                self.send_json({"error": f"Law '{law_id}' not found"}, 404)
                return

            LAWS_FILE.write_text("".join(new_blocks).strip() + "\n", encoding="utf-8")
            self.send_json({"deleted": law_id})
        else:
            self.send_response(404)
            self.end_headers()


class ThreadedServer(http.server.ThreadingHTTPServer):
    allow_reuse_address = True


def main():
    server = ThreadedServer(("127.0.0.1", PORT), CHPHandler)
    url = f"http://localhost:{PORT}"
    print(f"CHP Dashboard running at {url}", flush=True)
    threading.Timer(0.5, webbrowser.open, args=[url]).start()
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    server.server_close()


if __name__ == "__main__":
    main()
