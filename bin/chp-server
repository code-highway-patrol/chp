#!/usr/bin/env python3
"""CHP Dashboard — local web server for viewing laws, creating rules, running checks, and viewing reports."""

import http.server
import json
import os
import re
import subprocess
import sys
import threading
import webbrowser
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import parse_qs, urlparse

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 5177
PROJECT_DIR = os.environ.get("CLAUDE_PROJECT_DIR", os.getcwd())
PLUGIN_ROOT = os.environ.get("CLAUDE_PLUGIN_ROOT", str(Path(__file__).resolve().parent.parent))
LAWS_FILE = Path(PROJECT_DIR) / "laws" / "chp-laws.txt"
REPORT_FILE = Path(PROJECT_DIR) / ".chp" / "report.json"


def parse_laws(text):
    laws = []
    current = None
    for line in text.splitlines():
        header = re.match(r"^#\s*===\s*Law:\s*(\S+)\s*===", line)
        if header:
            current = {"id": header.group(1)}
            laws.append(current)
            continue
        if current is None or line.startswith("#"):
            continue
        if line.startswith("intent:"):
            current["intent"] = line.split(":", 1)[1].strip()
        elif line.startswith("check:"):
            current["check"] = line.split(":", 1)[1].strip()
        elif line.startswith("reaction:"):
            current["reaction"] = line.split(":", 1)[1].strip()
    return laws


def serialize_law(law):
    lines = [f"# === Law: {law['id']} ==="]
    lines.append(f"intent: {law.get('intent', '')}")
    if law.get("check"):
        lines.append(f"check: {law['check']}")
    lines.append(f"reaction: {law.get('reaction', 'warn')}")
    return "\n".join(lines)


