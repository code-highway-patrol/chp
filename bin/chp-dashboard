#!/usr/bin/env python3
"""Start the CHP dashboard if it isn't already running."""

import os
import socket
import subprocess
import sys
from pathlib import Path

PORT = 5177


def is_running():
    try:
        s = socket.create_connection(("127.0.0.1", PORT), timeout=1)
        s.close()
        return True
    except (ConnectionRefusedError, OSError):
        return False


def main():
    if is_running():
        print(f"CHP Dashboard already running at http://localhost:{PORT}")
        return

    server_script = Path(__file__).resolve().parent / "chp-server"
    env = {**os.environ}
    if "CLAUDE_PROJECT_DIR" not in env:
        env["CLAUDE_PROJECT_DIR"] = os.getcwd()
    subprocess.Popen(
        [sys.executable, str(server_script)],
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        creationflags=getattr(subprocess, "CREATE_NO_WINDOW", 0) | getattr(subprocess, "DETACHED_PROCESS", 0),
    )
    print(f"CHP Dashboard started at http://localhost:{PORT}")


if __name__ == "__main__":
    main()
