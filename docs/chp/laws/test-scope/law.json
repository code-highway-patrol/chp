{
  "name": "test-scope",
  "severity": "error",
  "hooks": ["pre-commit"],
  "enabled": true,
  "intent": "Ensure test files are properly scoped and isolated. Tests should only interact with designated test directories.",
  "autoFix": "never",
  "checks": [
    {
      "id": "test-scope-validation",
      "type": "pattern",
      "config": {"pattern": "test[.]only|describe[.]only"},
      "severity": "block",
      "message": "Remove .only() from tests before committing"
    }
  ],
  "include": ["**/*.ts"],
  "created": "2026-04-25T00:00:00Z",
  "failures": 0,
  "tightening_level": 0
}
