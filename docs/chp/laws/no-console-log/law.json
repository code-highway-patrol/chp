{
  "name": "no-console-log",
  "severity": "error",
  "hooks": ["pre-commit", "pre-tool"],
  "enabled": true,
  "intent": "Prevent console.log() statements in code. Use logger.info(), logger.error(), or logger.debug() instead.",
  "autoFix": "never",
  "checks": [
    {
      "id": "no-console-log",
      "type": "pattern",
      "config": {"pattern": "console[.]log[(]"},
      "severity": "block",
      "message": "Use logger.info() instead of console.log()"
    }
  ],
  "include": ["**/*.js", "**/*.ts", "**/*.jsx", "**/*.tsx", "**/*.mjs"],
  "exclude": ["**/node_modules/**", "**/dist/**", "**/build/**"],
  "created": "2026-04-25T00:00:00Z",
  "failures": 0,
  "tightening_level": 0
}
