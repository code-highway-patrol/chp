{
  "probes": [
    {
      "description": "Stripe secret key",
      "content": "const apiKey = \"sk_live_PROBE_TEST_NOT_A_REAL_KEY_XXXXXXXXX\";",
      "extension": "js",
      "shouldDetect": true
    },
    {
      "description": "Google API key",
      "content": "const apiKey = \"AIzaSyA1234567890123456789012345678901234\";",
      "extension": "js",
      "shouldDetect": true
    },
    {
      "description": "AWS access key",
      "content": "const apiKey = \"AKIAIOSFODNN7EXAMPLE\";",
      "extension": "js",
      "shouldDetect": true
    },
    {
      "description": "GitHub token",
      "content": "const token = \"ghp_abcdefghijklmnopqrstuvwxyz1234567890\";",
      "extension": "js",
      "shouldDetect": true
    },
    {
      "description": "Slack bot token",
      "content": "const token = \"xoxb-PROBE_TEST-NOT_REAL-XXXXXXXXXXXXXXXXXX\";",
      "extension": "js",
      "shouldDetect": true
    },
    {
      "description": "Env variable reference (clean)",
      "content": "const apiKey = process.env.STRIPE_SECRET_KEY;",
      "extension": "js",
      "shouldDetect": false
    },
    {
      "description": "Commented key (clean)",
      "content": "// const apiKey = \"sk_live_example\";",
      "extension": "js",
      "shouldDetect": false
    },
    {
      "description": "RSA private key (known gap)",
      "content": "-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA1234567890\n-----END RSA PRIVATE KEY-----",
      "extension": "pem",
      "shouldDetect": true
    },
    {
      "description": "Bearer JWT token (known gap)",
      "content": "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.dozjgNryP4J3jVmNHl0w5N_XgL0n3I9PlFUP0THsR8U",
      "extension": "js",
      "shouldDetect": true
    }
  ]
}
