{
  "name": "chp",
  "displayName": "Code Health Protocol",
  "description": "Highway Patrol for your code - enforcing traffic laws, catching speeders, and keeping your codebase safe",
  "version": "1.0.0",
  "publisher": "justi",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/chp",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/chp.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/chp/issues"
  },
  "categories": [
    "Code Quality",
    "Analysis",
    "Developer Tools"
  ],
  "keywords": [
    "static-analysis",
    "code-quality",
    "linting",
    "rules",
    "standards",
    "best-practices",
    "security",
    "code-review"
  ],
  "capabilities": {
    "skills": true,
    "agents": true,
    "hooks": true,
    "commands": true
  },
  "engines": {
    "gemini": ">=1.0.0"
  },
  "components": {
    "agents": {
      "directory": "agents",
      "items": [
        {
          "id": "chief",
          "name": "Chief of Police",
          "description": "Manage the CHP law lifecycle - creation, registration, updates, and coordination",
          "file": "agents/chief.md"
        },
        {
          "id": "detective",
          "name": "Detective",
          "description": "Analyze codebase and provide context and guidance for law enforcement",
          "file": "agents/detective.md"
        },
        {
          "id": "officer",
          "name": "Officer",
          "description": "Enforce CHP laws and report violations",
          "file": "agents/officer.md"
        }
      ]
    },
    "skills": {
      "directory": "skills",
      "items": [
        {"id": "health-check", "file": "skills/health-check.md"},
        {"id": "enforce-laws", "file": "skills/enforce-laws.md"},
        {"id": "create-law", "file": "skills/create-law.md"},
        {"id": "investigate", "file": "skills/investigate.md"},
        {"id": "write-laws", "file": "skills/write-laws/skill.md"}
      ]
    },
    "hooks": {
      "directory": "hooks",
      "items": [
        {"id": "pre-commit", "file": "hooks/pre-commit.md"},
        {"id": "pre-push", "file": "hooks/pre-push.md"},
        {"id": "pre-prompt", "file": "hooks/pre-prompt.md"},
        {"id": "post-analysis", "file": "hooks/post-analysis.md"}
      ]
    },
    "commands": {
      "directory": "commands",
      "items": [
        {"id": "analyze", "file": "commands/analyze.md"},
        {"id": "check", "file": "commands/check.md"},
        {"id": "validate", "file": "commands/validate.md"}
      ]
    }
  }
}
