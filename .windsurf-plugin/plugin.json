{
  "name": "chp",
  "displayName": "CHP - Code Highway Patrol",
  "description": "Code quality enforcement with traffic laws and automated violation detection. Enforces coding standards through AI agents and automated hooks.",
  "version": "1.0.0",
  "author": {
    "name": "CHP Contributors",
    "email": "justi"
  },
  "homepage": "https://github.com/yourusername/chp",
  "repository": "https://github.com/yourusername/chp",
  "license": "MIT",
  "keywords": [
    "code-quality",
    "linting",
    "enforcement",
    "traffic-laws",
    "pre-commit",
    "hooks",
    "ai-agent",
    "mcp-server"
  ],
  "windsurf": {
    "cascade": {
      "skills": "./.claude/skills/",
      "commands": "./.claude/commands/",
      "agents": "./agents/",
      "context": "./docs/chp/"
    },
    "mcp": {
      "enabled": true,
      "config": "./.windsurf-plugin/mcp-server.json"
    },
    "hooks": "./.claude/settings.json"
  },
  "capabilities": [
    "code-analysis",
    "rule-enforcement",
    "pre-commit-hooks",
    "law-creation",
    "violation-detection",
    "context-aware-guidance"
  ],
  "ai_integration": {
    "supports_cascade": true,
    "supports_mcp": true,
    "context_files": [
      "docs/chp/*.md",
      "docs/chp/laws/*/law.json",
      "docs/chp/laws/*/guidance.md"
    ]
  }
}
